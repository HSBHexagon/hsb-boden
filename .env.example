# hsb-boden lead endpoint.
# LEAD_WEBHOOK_URL is server-only (no PUBLIC_ prefix) - never exposed to the browser.
# Point it at a free delivery target, e.g. a Google Apps Script Web App tied to
# the CRM-Light Sheet (see GOOGLE_SHEETS_CRM_SETUP.md) - no n8n subscription needed.
LEAD_WEBHOOK_URL=
# PUBLIC_LEAD_FORM_ENABLED toggles the form's online-delivery UI; flip to "true"
# only once LEAD_WEBHOOK_URL is actually configured.
PUBLIC_LEAD_FORM_ENABLED=false

# GitHub Models via Cloudflare AI Gateway PoC.
# Disabled by default. These values are server-only and must be configured as
# encrypted Cloudflare Pages secrets/variables, never committed with real values.
AI_POC_ENABLED=false
AI_POC_ACCESS_TOKEN=
CF_ACCOUNT_ID=
CF_AI_GATEWAY_ID=
CF_AIG_TOKEN=

# The GitHub Models token is intentionally NOT a Pages variable. Store it in the
# Cloudflare AI Gateway custom-provider credential for provider slug github-models.
