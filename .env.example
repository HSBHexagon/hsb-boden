# hsb-boden lead endpoint. Both variables are server-only (no PUBLIC_ prefix).
# Preferred atomic config: authenticated Apps Script URL + token in ONE secret.
# Use only fake/local values here; never commit a real URL or token.
# JSON schema: {"url":"https://script.google.com/macros/s/<id>/exec","token":"<32-512 random chars>"}
# LEAD_WEBHOOK_CONFIG=
# Temporary backwards-compatible fallback during the zero-downtime cutover.
LEAD_WEBHOOK_URL=
# PUBLIC_LEAD_FORM_ENABLED toggles the form's online-delivery UI; flip to "true"
# only once one server-side webhook binding is actually configured.
PUBLIC_LEAD_FORM_ENABLED=false
