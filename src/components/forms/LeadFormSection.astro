---
import { LeadForm } from "./LeadForm";
---

<section class="section border-b border-hsb-line" id="kontaktformular">
  <div class="container grid gap-12 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
    <div>
      <h2 class="h2">Kostenlose Ersteinschätzung anfordern</h2>
      <p class="lead mt-4">
        HSB bewertet Belastungsprofil, Untergrund und Sanierungsoptionen vor Ort — kostenlos und ohne Kaufverpflichtung. Drei Angaben genügen für eine erste Einschätzung:
      </p>
      <div class="mt-8 space-y-4 border-t border-hsb-line pt-8">
        {[
          ["Branche und Nutzung", "Welche Belastungen sind relevant?"],
          ["Fläche und Situation", "Neubau oder Sanierung?"],
          ["Zeitfenster", "Wann ist der Eingriff möglich?"],
        ].map(([label, hint]) => (
          <div class="flex items-start gap-3">
            <span class="mt-1 size-1.5 shrink-0 rounded-full bg-hsb-red"></span>
            <div>
              <p class="text-sm font-bold">{label}</p>
              <p class="text-xs text-hsb-steel">{hint}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
    <LeadForm client:load />
  </div>
</section>
