---
import { LeadForm } from "./LeadForm";
---

<section class="section" id="kontaktformular">
  <div class="container grid gap-10 lg:grid-cols-[0.9fr_1.1fr]">
    <div>
      <p class="eyebrow">Lead-System</p>
      <h2 class="h2 mt-3">Qualifizierte Anfrage statt generischem Kontakt</h2>
      <p class="lead mt-4">Das Formular fragt die Informationen ab, die für eine technische Ersteinschätzung wirklich relevant sind: Branche, Projektart, Belastungen, Fläche und Betriebssituation.</p>
    </div>
    <LeadForm client:load />
  </div>
</section>
