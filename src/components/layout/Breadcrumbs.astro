---
interface Crumb {
  name: string;
  path: string;
}

interface Props {
  items: Crumb[];
}

const { items } = Astro.props;
---

<nav class="container py-4 text-sm text-hsb-steel" aria-label="Breadcrumb">
  <ol class="flex flex-wrap items-center gap-2">
    {items.map((item, index) => (
      <li class="flex items-center gap-2">
        {index > 0 && <span aria-hidden="true">/</span>}
        <a class={index === items.length - 1 ? "font-bold text-hsb-black" : "hover:text-hsb-red"} href={item.path}>{item.name}</a>
      </li>
    ))}
  </ol>
</nav>
