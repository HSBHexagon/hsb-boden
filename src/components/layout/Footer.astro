---
import { footerGroups } from "../../data/navigation";
import { site } from "../../data/site";
---

<footer class="border-t border-hsb-line bg-hsb-black text-white">
  <div class="container grid gap-10 py-14 lg:grid-cols-[1.2fr_2fr]">
    <div>
      <div class="mb-4">
        <img src="/brand/hsb-boden-logo.png" alt="Hexagon Säurebau GmbH" class="h-12 w-auto object-contain" loading="lazy" width="148" height="48" />
      </div>
      <p class="max-w-md text-sm leading-7 text-white/70">{site.description}</p>
      <p class="mt-6 text-sm text-white/60">Gronau · NRW · Industrieböden, Säureschutz und Sanierung für produktionskritische Bereiche.</p>
      <button
        type="button"
        class="mt-5 text-left text-sm font-bold text-white/70 underline decoration-white/20 underline-offset-4 hover:text-white"
        data-cookie-reset
      >
        Cookie-Einstellungen
      </button>
    </div>
    <div class="grid gap-8 sm:grid-cols-3">
      {footerGroups.map((group) => (
        <div>
          <h2 class="mb-4 text-sm font-black uppercase tracking-wide text-white">{group.title}</h2>
          <ul class="space-y-3 text-sm text-white/70">
            {group.links.map((link) => (
              <li><a class="hover:text-white" href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</footer>
