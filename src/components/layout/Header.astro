---
import { navigation } from "../../data/navigation";
---

<style>
  #site-header {
    transition: background 200ms ease, border-color 200ms ease, box-shadow 200ms ease, color 200ms ease;
  }
  /* At top: light header, dark text */
  #site-header:not(.scrolled) {
    background: rgba(255, 255, 255, 0.97);
    border-bottom: 1px solid rgba(15, 17, 20, 0.08);
    box-shadow: none;
    color: #0f1114;
  }
  #site-header:not(.scrolled) .nav-links a {
    color: rgba(15, 17, 20, 0.65);
  }
  #site-header:not(.scrolled) .nav-links a:hover {
    color: #0f1114;
  }
  #site-header:not(.scrolled) #mobile-menu-toggle {
    border-color: rgba(15, 17, 20, 0.18);
    color: #0f1114;
  }
  /* Scrolled: dark header, white text */
  #site-header.scrolled {
    background: rgba(15, 17, 20, 0.97);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.32);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: white;
  }
  #site-header.scrolled .nav-links a {
    color: rgba(255, 255, 255, 0.72);
  }
  #site-header.scrolled .nav-links a:hover {
    color: white;
  }
  #site-header.scrolled #mobile-menu-toggle {
    border-color: rgba(255, 255, 255, 0.2);
    color: white;
  }
</style>

<header id="site-header" class="sticky top-0 z-40">
  <div class="container flex min-h-[72px] items-center justify-between gap-6">

    <!-- Logo -->
    <a href="/" class="flex shrink-0 items-center no-underline" aria-label="HSB Hexagon Säurebau Startseite">
      <img src="/brand/hsb-boden-logo.png" alt="Hexagon Säurebau GmbH" class="h-11 w-auto object-contain" width="140" height="44" />
    </a>

    <!-- Desktop nav -->
    <nav class="nav-links hidden items-center gap-6 text-sm font-bold lg:flex" aria-label="Hauptnavigation">
      {navigation.filter(n => n.href !== "/kontakt/").map((item) => (
        <a class="transition-colors" href={item.href}>{item.label}</a>
      ))}
    </nav>

    <!-- CTA + Mobile button -->
    <div class="flex items-center gap-3">
      <div class="hidden lg:block">
        <a class="button-primary" href="/kontakt/">Ersteinschätzung</a>
      </div>

      <button
        id="mobile-menu-toggle"
        class="flex size-10 items-center justify-center rounded border lg:hidden"
        aria-label="Navigation öffnen"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="icon-menu" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M2 4.5h14M2 9h14M2 13.5h14" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
        </svg>
        <svg id="icon-close" class="hidden" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M3 3l12 12M15 3L3 15" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

  </div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="hidden border-t border-white/10 bg-hsb-black"
    aria-label="Mobile Navigation"
  >
    <div class="container py-4">
      {navigation.map((item) => (
        <a
          href={item.href}
          class="flex items-center border-b border-white/10 py-3.5 text-sm font-bold text-white/78 last:border-0 hover:text-white"
        >
          {item.label}
        </a>
      ))}
      <div class="pt-4">
        <a class="button-primary w-full text-center" href="/kontakt/">Ersteinschätzung anfordern</a>
      </div>
    </div>
  </nav>
</header>

<script>
  const header = document.getElementById("site-header") as HTMLElement | null;
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconMenu = document.getElementById("icon-menu");
  const iconClose = document.getElementById("icon-close");

  function updateHeader() {
    if (!header) return;
    header.classList.toggle("scrolled", window.scrollY > 72);
  }

  window.addEventListener("scroll", updateHeader, { passive: true });
  updateHeader();

  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
    iconMenu?.classList.toggle("hidden", open);
    iconClose?.classList.toggle("hidden", !open);
    // Keep dark when menu open
    if (open && header) header.classList.add("scrolled");
    else updateHeader();
  });
</script>
