---
import { navigation } from "../../data/navigation";
import { supportedLanguages } from "../../data/localization";
---

<style>
  #header-scroll-sentinel {
    position: absolute;
    inset-block-start: 0;
    height: 1px;
    width: 1px;
    pointer-events: none;
  }
  #site-header {
    transition: background 200ms ease, border-color 200ms ease, box-shadow 200ms ease, color 200ms ease;
  }
  /* Durchgehend dunkler, aber gegenueber dem Hero leicht aufgehellter Header.
     So bleibt der industrielle Charakter erhalten, ohne dass Mobile oben zu schwer wird. */
  #site-header {
    background: #171b22;
    color: #ffffff;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }
  #site-header .nav-links a {
    color: rgba(255, 255, 255, 0.72);
  }
  #site-header .nav-links a:hover {
    color: #ffffff;
  }
  #site-header #mobile-menu-toggle {
    border-color: rgba(255, 255, 255, 0.22);
    color: #ffffff;
  }
  /* Scrolled: leichte Transluzenz + Elevation als Scroll-Hinweis ueber hellem Content. */
  #site-header.scrolled {
    background: rgba(23, 27, 34, 0.94);
    border-bottom-color: rgba(255, 255, 255, 0.12);
    box-shadow: 0 4px 22px rgba(0, 0, 0, 0.26);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
</style>

<div id="header-scroll-sentinel" aria-hidden="true"></div>
<header id="site-header" class="sticky top-0 z-40">
  <div class="container flex min-h-[72px] items-center justify-between gap-6">

    <!-- Logo: helle Marken-Variante, fuer den durchgehend dunklen Header gebaut (transparenter PNG-Hintergrund) -->
    <a href="/" class="logo-lockup flex shrink-0 items-center no-underline" aria-label="HSB Hexagon Säurebau Startseite">
      <img src="/brand/hsb-boden-logo-dark.png" alt="HSB Hexagon Säurebau GmbH" class="h-11 w-auto object-contain" width="60" height="44" />
    </a>

    <!-- Rechter Cluster: Navigation und CTA bilden eine bewusste Gruppe -->
    <div class="flex items-center gap-4 lg:gap-10">
      <nav class="nav-links hidden items-center gap-8 text-[0.825rem] font-black uppercase tracking-widest lg:flex" aria-label="Hauptnavigation">
        {navigation.filter(n => n.href !== "/kontakt/").map((item) => (
          <a class="relative py-2 transition-colors hover:text-white group" href={item.href}>
            <span>{item.label}</span>
            <span class="absolute bottom-0 left-0 h-0.5 w-0 bg-hsb-red transition-all duration-300 group-hover:w-full"></span>
          </a>
        ))}
      </nav>

      <div class="hidden items-center gap-1 rounded-[4px] border border-white/10 p-1 xl:flex" aria-label="Sprachauswahl">
        {supportedLanguages.map((language) => (
          <a
            href={`?lang=${language.code}`}
            class="language-choice flex h-8 min-w-8 items-center justify-center rounded-[2px] px-2 text-[0.68rem] font-black uppercase text-white/60 transition hover:bg-white/10 hover:text-white"
            data-language-choice={language.code}
            title={language.label}
          >
            {language.code}
          </a>
        ))}
      </div>

      <div class="hidden lg:block">
        <a class="button-primary px-8" href="/kontakt/">Ersteinschätzung</a>
      </div>

      <button
        id="mobile-menu-toggle"
        class="flex size-10 items-center justify-center rounded border lg:hidden"
        aria-label="Navigation öffnen"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="icon-menu" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M2 4.5h14M2 9h14M2 13.5h14" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
        </svg>
        <svg id="icon-close" class="hidden" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M3 3l12 12M15 3L3 15" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

  </div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="hidden border-t border-white/10 bg-[#171b22]"
    aria-label="Mobile Navigation"
  >
    <div class="container py-4">
      {navigation.map((item) => (
        <a
          href={item.href}
          class="flex items-center border-b border-white/10 py-3.5 text-sm font-bold text-white/78 last:border-0 hover:text-white"
        >
          {item.label}
        </a>
      ))}
      <div class="mt-4 grid grid-cols-6 gap-2" aria-label="Sprachauswahl">
        {supportedLanguages.map((language) => (
          <a
            href={`?lang=${language.code}`}
            class="language-choice flex h-10 items-center justify-center rounded-[2px] border border-white/10 text-xs font-black uppercase text-white/70 hover:border-white/30 hover:text-white"
            data-language-choice={language.code}
            title={language.label}
          >
            {language.code}
          </a>
        ))}
      </div>
      <div class="pt-4">
        <a class="button-primary w-full text-center" href="/kontakt/">Ersteinschätzung anfordern</a>
      </div>
    </div>
  </nav>
</header>

<script>
  const header = document.getElementById("site-header") as HTMLElement | null;
  const sentinel = document.getElementById("header-scroll-sentinel");
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconMenu = document.getElementById("icon-menu");
  const iconClose = document.getElementById("icon-close");
  let pastHeaderSentinel = false;

  function syncHeaderState() {
    if (!header) return;
    const menuOpen = toggle?.getAttribute("aria-expanded") === "true";
    header.classList.toggle("scrolled", pastHeaderSentinel || menuOpen);
  }

  if (header && sentinel && "IntersectionObserver" in window) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        pastHeaderSentinel = !entry.isIntersecting;
        syncHeaderState();
      },
      { rootMargin: "-72px 0px 0px 0px", threshold: 0 },
    );
    observer.observe(sentinel);
  }
  syncHeaderState();

  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
    iconMenu?.classList.toggle("hidden", open);
    iconClose?.classList.toggle("hidden", !open);
    syncHeaderState();
  });

  function markLanguageChoice(code: string | null) {
    document.querySelectorAll<HTMLElement>("[data-language-choice]").forEach((item) => {
      const active = item.dataset.languageChoice === code;
      item.classList.toggle("bg-white/10", active);
      item.classList.toggle("text-white", active);
      item.setAttribute("aria-current", active ? "true" : "false");
    });
  }

  const languageStorageKey = "hsb_language_offer_v1";
  const currentLanguage = new URLSearchParams(window.location.search).get("lang") ?? window.localStorage.getItem(languageStorageKey) ?? "de";
  markLanguageChoice(currentLanguage);

  document.querySelectorAll<HTMLAnchorElement>("[data-language-choice]").forEach((item) => {
    item.addEventListener("click", (event) => {
      const code = item.dataset.languageChoice;
      if (!code) return;
      event.preventDefault();
      const url = new URL(window.location.href);
      url.searchParams.set("lang", code);
      window.history.replaceState({}, "", url);
      window.localStorage.setItem(languageStorageKey, code);
      window.dispatchEvent(new CustomEvent("hsb:language-choice", { detail: { code } }));
      markLanguageChoice(code);
    });
  });
</script>
