---
import { navigation } from "../../data/navigation";
import { site } from "../../data/site";

const phoneHref = site.phone.replace("(0)", "").replace(/[^\d+]/g, "");
---

<style>
  #header-scroll-sentinel {
    position: absolute;
    inset-block-start: 0;
    height: 1px;
    width: 1px;
    pointer-events: none;
  }
  #site-header {
    transition: background 200ms ease, border-color 200ms ease, box-shadow 200ms ease, color 200ms ease;
  }
  /* Durchgehend dunkler Header (industrieller Charakter).
     Oben: deckungsgleich mit dem dunklen Hero (#161a20) -> nahtloser Top-Fold.
     Auf hellen Unterseiten-Heros bleibt es eine klare dunkle Leiste. */
  #site-header {
    background: #161a20;
    color: #ffffff;
    border-bottom: 1px solid transparent;
  }
  #site-header .nav-links a {
    color: rgba(255, 255, 255, 0.72);
  }
  #site-header .nav-links a:hover {
    color: #ffffff;
  }
  #site-header #mobile-menu-toggle {
    border-color: rgba(255, 255, 255, 0.22);
    color: #ffffff;
  }
  /* Scrolled: leichte Transluzenz + Elevation als Scroll-Hinweis ueber hellem Content. */
  #site-header.scrolled {
    background: rgba(22, 26, 32, 0.92);
    border-bottom-color: rgba(255, 255, 255, 0.08);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.32);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
</style>

<div id="header-scroll-sentinel" aria-hidden="true"></div>
<header id="site-header" class="sticky top-0 z-40">
  <div class="container flex min-h-[72px] items-center justify-between gap-6">

    <!-- Logo: helle Marken-Variante, fuer den durchgehend dunklen Header gebaut (transparenter PNG-Hintergrund) -->
    <a href="/" class="logo-lockup flex shrink-0 items-center no-underline" aria-label="HSB Hexagon Säurebau Startseite">
      <img src="/brand/hsb-boden-logo-dark.png" alt="HSB Hexagon Säurebau GmbH" class="h-11 w-auto object-contain" width="60" height="44" />
    </a>

    <!-- Rechter Cluster: Navigation und CTA bilden eine bewusste Gruppe,
         damit der Header als Ganzes wirkt (Logo links, Aktionen rechts) und
         die Navigation nicht isoliert in der Mitte schwebt. -->
    <div class="flex items-center gap-4 xl:gap-8">
      <nav class="nav-links hidden items-center gap-4 text-sm font-bold lg:flex xl:gap-6" aria-label="Hauptnavigation">
        {navigation.filter(n => n.href !== "/kontakt/").map((item) => (
          <a class="transition-colors" href={item.href}>{item.label}</a>
        ))}
      </nav>

      <a
        class="hidden items-center gap-2 whitespace-nowrap text-sm font-bold text-white/72 transition-colors hover:text-white xl:flex"
        href={`tel:${phoneHref}`}
        aria-label={`HSB anrufen: ${site.phone}`}
      >
        <svg width="15" height="15" viewBox="0 0 14 14" fill="none" aria-hidden="true">
          <path d="M12.7 10.3c-.3-.5-2-1.4-2.4-1.6-.4-.2-.7-.2-1 .2-.2.3-.8 1-.9 1.1-.2.1-.4.1-.6 0-1-.4-2.6-1.7-3.5-3-.2-.3-.1-.5 0-.7.2-.2.5-.5.6-.7.2-.3.2-.6 0-.9-.2-.4-1-2.1-1.4-2.5C3.1 2 2.9 2 2.6 2c-.3 0-.8.2-1.1.6C1 3.2.4 4 .4 5.3c0 1.4.8 2.8 1 3 .2.3 2.1 3.3 5.1 4.7 3 1.3 3 .9 3.5.8.5-.1 1.7-.7 1.9-1.4.3-.7.3-1.2.1-1.4h-.3z" fill="currentColor"/>
        </svg>
        <span>{site.phone}</span>
      </a>

      <div class="hidden lg:block">
        <a class="button-primary" href="/kontakt/">Ersteinschätzung</a>
      </div>

      <button
        id="mobile-menu-toggle"
        class="flex size-10 items-center justify-center rounded border lg:hidden"
        aria-label="Navigation öffnen"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="icon-menu" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M2 4.5h14M2 9h14M2 13.5h14" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
        </svg>
        <svg id="icon-close" class="hidden" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M3 3l12 12M15 3L3 15" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
        </svg>
      </button>
    </div>

  </div>

  <!-- Mobile menu -->
  <nav
    id="mobile-menu"
    class="hidden border-t border-white/10 bg-hsb-black"
    aria-label="Mobile Navigation"
  >
    <div class="container py-4">
      {navigation.map((item) => (
        <a
          href={item.href}
          class="flex items-center border-b border-white/10 py-3.5 text-sm font-bold text-white/78 last:border-0 hover:text-white"
        >
          {item.label}
        </a>
      ))}
      <a
        href={`tel:${phoneHref}`}
        class="mt-4 flex items-center justify-center gap-2 rounded border border-white/20 px-4 py-3 text-sm font-bold text-white hover:border-white/40"
        aria-label={`HSB anrufen: ${site.phone}`}
      >
        <span>Direkt anrufen</span>
        <span class="text-white/65">{site.phone}</span>
      </a>
      <div class="pt-4">
        <a class="button-primary w-full text-center" href="/kontakt/">Ersteinschätzung anfordern</a>
      </div>
    </div>
  </nav>
</header>

<script>
  const header = document.getElementById("site-header") as HTMLElement | null;
  const sentinel = document.getElementById("header-scroll-sentinel");
  const toggle = document.getElementById("mobile-menu-toggle");
  const menu = document.getElementById("mobile-menu");
  const iconMenu = document.getElementById("icon-menu");
  const iconClose = document.getElementById("icon-close");
  let pastHeaderSentinel = false;

  function syncHeaderState() {
    if (!header) return;
    const menuOpen = toggle?.getAttribute("aria-expanded") === "true";
    header.classList.toggle("scrolled", pastHeaderSentinel || menuOpen);
  }

  if (header && sentinel && "IntersectionObserver" in window) {
    const observer = new IntersectionObserver(
      ([entry]) => {
        pastHeaderSentinel = !entry.isIntersecting;
        syncHeaderState();
      },
      { rootMargin: "-72px 0px 0px 0px", threshold: 0 },
    );
    observer.observe(sentinel);
  }
  syncHeaderState();

  toggle?.addEventListener("click", () => {
    const open = menu?.classList.toggle("hidden") === false;
    toggle.setAttribute("aria-expanded", String(open));
    iconMenu?.classList.toggle("hidden", open);
    iconClose?.classList.toggle("hidden", !open);
    syncHeaderState();
  });
</script>
