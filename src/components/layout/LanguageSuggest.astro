---
// Sprachangebot: Auf deutschen Seiten wird Besuchern mit nicht-deutscher
// Browsersprache die passende Sprachversion angeboten (en/tr/nl/pl/fr direkt,
// alle übrigen Sprachen -> Englisch). Entscheidung in localStorage.
import type { Lang } from "../../lib/i18n";

interface Props {
  lang?: Lang;
}

const { lang = "de" } = Astro.props;
---

{lang === "de" && (
  <div
    id="lang-suggest"
    class="hidden border-b border-hsb-line bg-white"
    role="region"
    aria-label="Language suggestion"
  >
    <div class="container flex flex-wrap items-center justify-between gap-2 py-2">
      <p class="text-xs font-bold text-hsb-black"><span id="lang-suggest-text"></span></p>
      <div class="flex items-center gap-2">
        <a id="lang-suggest-link" class="button-primary !px-3 !py-1.5 text-xs" href="/en/"></a>
        <button id="lang-suggest-dismiss" class="text-xs font-bold text-hsb-steel underline hover:text-hsb-black"></button>
      </div>
    </div>
  </div>
)}

<script>
  import { initLanguageSuggest } from "../../lib/languageSuggest";

  // Wir führen die Initialisierung nur aus, wenn wir uns im Browser befinden
  if (typeof window !== 'undefined') {
    initLanguageSuggest(document, navigator, localStorage);
  }
</script>
