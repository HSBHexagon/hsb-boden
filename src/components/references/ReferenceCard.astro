---
import { services } from "../../data/services";

interface ReferenceItem {
  id: string;
  displayName: string;
  displayLocation: string;
  industry: string;
  systems: readonly string[];
  projectType: string;
  challenge: string;
  solution: string;
  result: string;
  approvalStatus: string;
  logo?: string;
  year?: string;
}

interface Props {
  reference: ReferenceItem;
}

const { reference } = Astro.props;
const serviceTitleMap = Object.fromEntries(services.map((service) => [service.slug, service.title]));
---

<article class="surface overflow-hidden p-0">
  <div class="flex items-start justify-between gap-4 border-b border-hsb-line p-6">
    <div>
      <p class="text-xs font-black uppercase tracking-wide text-hsb-red">{reference.projectType}</p>
      <h3 class="h3 mt-2">{reference.displayName}</h3>
      <p class="mt-1 text-sm font-bold text-hsb-steel">
        {reference.displayLocation}
        {reference.year ? <span class="ml-2 text-hsb-line">· {reference.year}</span> : null}
      </p>
    </div>
    <div class="flex flex-col items-end gap-3">
      <span class="rounded border border-hsb-line px-2 py-1 text-xs font-bold text-hsb-steel">{reference.approvalStatus === "approved" ? "freigegeben" : "anonymisiert"}</span>
      {reference.logo ? (
        <div class="grid h-10 w-28 place-items-center rounded bg-hsb-mist px-3">
          <img src={reference.logo} alt={`${reference.displayName} Logo`} class="max-h-5 w-auto max-w-full object-contain" loading="lazy" />
        </div>
      ) : null}
    </div>
  </div>
  <dl class="grid gap-4 p-6 text-sm leading-6 text-hsb-steel">
    <div><dt class="font-black text-hsb-black">Herausforderung</dt><dd>{reference.challenge}</dd></div>
    <div><dt class="font-black text-hsb-black">Lösung</dt><dd>{reference.solution}</dd></div>
    <div><dt class="font-black text-hsb-black">Ergebnis</dt><dd>{reference.result}</dd></div>
  </dl>
  <div class="flex flex-wrap gap-2 border-t border-hsb-line p-6">
    {reference.systems.map((system) => <span class="rounded bg-hsb-mist px-2 py-1 text-xs font-bold text-hsb-steel">{serviceTitleMap[system] ?? system}</span>)}
  </div>
</article>
