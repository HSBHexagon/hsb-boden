---
import { serviceTitleMap } from "../../data/services";

interface ReferenceItem {
  id: string;
  displayName: string;
  displayLocation: string;
  industry: string;
  systems: readonly string[];
  projectType: string;
  challenge: string;
  solution: string;
  result: string;
  approvalStatus: string;
  logo?: string;
  year?: string;
}

interface Props {
  reference: ReferenceItem;
}

const { reference } = Astro.props;
---

<article class="surface group overflow-hidden p-0 border-hsb-line/60 hover:border-hsb-red/40 transition-colors duration-300">
  <div class="flex items-start justify-between gap-4 border-b border-hsb-line/50 p-6 lg:p-7">
    <div>
      <div class="flex items-center gap-2 mb-2">
        <span class="size-1 bg-hsb-red"></span>
        <p class="text-[0.65rem] font-black uppercase tracking-[0.2em] text-hsb-red">{reference.projectType}</p>
      </div>
      <h3 class="text-xl font-black leading-tight text-hsb-black transition-colors group-hover:text-hsb-red">{reference.displayName}</h3>
      <div class="mt-2 flex items-center gap-2 text-[0.8rem] font-bold text-hsb-steel/80">
        <span>{reference.displayLocation}</span>
        {reference.year ? <span class="size-1 rounded-full bg-hsb-line"></span><span>{reference.year}</span> : null}
      </div>
    </div>
    <div class="flex flex-col items-end gap-3">
      <span class="rounded-[2px] border border-hsb-line bg-hsb-mist px-2 py-0.5 text-[0.65rem] font-black uppercase tracking-wider text-hsb-steel">{reference.approvalStatus === "approved" ? "freigegeben" : "anonymisiert"}</span>
      {reference.logo ? (
        <div class="grid h-10 w-28 place-items-center rounded bg-white border border-hsb-line/30 px-3 shadow-sm">
          <img src={reference.logo} alt={`${reference.displayName} Logo`} class="max-h-5 w-auto max-w-full grayscale opacity-70 contrast-125" loading="lazy" />
        </div>
      ) : null}
    </div>
  </div>
  <div class="grid gap-6 p-6 lg:p-7 text-[0.9rem] leading-7 text-hsb-steel">
    <div><p class="text-[0.65rem] font-black uppercase tracking-widest text-hsb-black mb-1 opacity-75">Anforderung</p><p class="font-medium text-hsb-black/80">{reference.challenge}</p></div>
    <div class="grid gap-1"><p class="text-[0.65rem] font-black uppercase tracking-widest text-hsb-black mb-1 opacity-75">Lösung & Ergebnis</p><p>{reference.solution} {reference.result}</p></div>
  </div>
  <div class="flex flex-wrap gap-2 border-t border-hsb-line/50 bg-[#fbfcfd] p-5">
    {reference.systems.map((system) => <span class="rounded-[2px] border border-hsb-line/60 px-2 py-1 text-[0.65rem] font-bold uppercase tracking-wide text-hsb-steel/90">{serviceTitleMap[system] ?? system}</span>)}
  </div>
</article>
