---
interface ReferenceItem {
  id: string;
  displayName: string;
  displayLocation: string;
  lat: number;
  lng: number;
}

interface Props {
  references: ReferenceItem[];
}

const { references } = Astro.props;

const points = references.map((reference) => ({
  ...reference,
  x: 8 + ((reference.lng - 5.5) / 9) * 84,
  y: 82 - ((reference.lat - 47) / 8.5) * 68,
}));
---

<div class="surface overflow-hidden bg-white">
  <div class="border-b border-hsb-line p-5">
    <p class="eyebrow">Referenzkarte</p>
    <h2 class="h3 mt-2">Freigegebene und anonymisierte Projektregionen</h2>
  </div>
  <svg viewBox="0 0 100 100" role="img" aria-label="Schematische Referenzkarte Deutschland" class="h-[360px] w-full bg-hsb-mist">
    <path d="M45 8 L58 10 L65 21 L72 28 L70 42 L78 55 L67 72 L58 90 L43 86 L33 78 L27 62 L20 48 L27 36 L25 20 Z" fill="#fff" stroke="#d8dde3" stroke-width="1.5" />
    {points.map((point) => (
      <g>
        <circle cx={point.x} cy={point.y} r="2.2" fill="#cb0000" />
        <text x={point.x + 3} y={point.y + 1} font-size="3.2" fill="#0f1114">{point.displayLocation}</text>
      </g>
    ))}
  </svg>
  <p class="p-5 text-sm leading-6 text-hsb-steel">Die Karte ist bewusst schematisch und zeigt bei nicht freigegebenen Projekten nur grobe Regionen.</p>
</div>
