---
import { germanyMapBounds, germanyMapViewBox, germanyStates, germanyTrustMarkers } from "../../data/germanyMap";

interface ReferenceItem {
  id: string;
  displayName: string;
  displayLocation: string;
  region: string;
  canShowExactLocation: boolean;
  lat: number;
  lng: number;
}

interface ClientLocation {
  name: string;
  city: string;
  region: string;
  lat: number;
  lng: number;
  branche: string;
}

interface Props {
  references: ReferenceItem[];
  clients?: readonly ClientLocation[];
}

const { references, clients = [] } = Astro.props;

const project = (lat: number, lng: number) => ({
  x: 4 + ((lng - germanyMapBounds.minLng) / (germanyMapBounds.maxLng - germanyMapBounds.minLng)) * (germanyMapViewBox.width - 8),
  y: 4 + ((germanyMapBounds.maxLat - lat) / (germanyMapBounds.maxLat - germanyMapBounds.minLat)) * (germanyMapViewBox.height - 8),
});

const points = references.map((reference) => ({
  ...reference,
  ...project(reference.lat, reference.lng),
}));

const clientPoints = clients.map((client) => ({
  ...client,
  ...project(client.lat, client.lng),
}));

const labelOffsets: Record<string, { dx: number; dy: number; anchor: "start" | "end" }> = {
  Husum: { dx: -2.4, dy: -2.8, anchor: "end" },
  Aachen: { dx: 2.2, dy: 0.4, anchor: "start" },
  Görlitz: { dx: -2.2, dy: 0.4, anchor: "end" },
  Oberstdorf: { dx: 2.1, dy: 2.5, anchor: "start" },
  Zeitz: { dx: 2.4, dy: -2.2, anchor: "start" },
  Bonefeld: { dx: 2.2, dy: 2.1, anchor: "start" },
  Gebesee: { dx: -2.2, dy: 1.8, anchor: "end" },
};

const stateLabelOverrides: Record<string, { x: number; y: number }> = {
  Berlin: { x: 81.3, y: 45.7 },
  Brandenburg: { x: 78.2, y: 38.7 },
};

const coveragePoints = germanyTrustMarkers.map((marker) => ({
  ...marker,
  ...project(marker.lat, marker.lng),
  ...(labelOffsets[marker.city] ?? { dx: 2, dy: 0, anchor: "start" as const }),
}));

// Regionen deduplizieren: kollidierende Inline-Labels auf der Karte ersetzen wir
// durch eine saubere Chip-Liste. Freigegebene exakte Standorte zuerst.
const seen = new Set<string>();
const regions: { label: string; exact: boolean }[] = [];
for (const reference of [...references].sort((a, b) => Number(b.canShowExactLocation) - Number(a.canShowExactLocation))) {
  if (seen.has(reference.displayLocation)) continue;
  seen.add(reference.displayLocation);
  regions.push({ label: reference.displayLocation, exact: reference.canShowExactLocation });
}
---

<div class="flex flex-col bg-white" data-testid="reference-map">
  <div class="border-b border-hsb-line p-6 lg:p-8">
    <p class="eyebrow">Deutschlandkarte</p>
    <h3 class="h3 mt-2">Bundesweite Referenzen und Kundenstandorte</h3>
  </div>
  <div class="flex min-h-[390px] items-center justify-center bg-[linear-gradient(135deg,#f3f5f7_0%,#ffffff_48%,#eef1f4_100%)] px-4 py-7 sm:min-h-[430px] sm:px-6 lg:py-8">
    <svg viewBox={`0 0 ${germanyMapViewBox.width} ${germanyMapViewBox.height}`} role="img" aria-label="Deutschlandkarte mit allen 16 Bundesländern und markierten Referenzstandorten" class="h-auto w-full max-w-[420px] overflow-visible" data-testid="germany-reference-map">
      <desc>Deutschlandkarte mit sichtbaren Bundesländergrenzen sowie Markern für Husum, Aachen, Görlitz, Oberstdorf, Zeitz, Bonefeld und Gebesee.</desc>
      <g>
        {germanyStates.map((state, index) => (
          <path
            d={state.d}
            data-state={state.name}
            fill={index % 2 === 0 ? "#ffffff" : "#f7f8fa"}
            stroke="#b9c0c8"
            stroke-width="0.42"
            vector-effect="non-scaling-stroke"
          >
            <title>{state.name}</title>
          </path>
        ))}
      </g>
      <g aria-hidden="true">
        {germanyStates.map((state) => {
          const label = stateLabelOverrides[state.name] ?? { x: state.labelX, y: state.labelY };

          return (
            <text x={label.x} y={label.y} text-anchor="middle" class="fill-hsb-steel text-[3px] font-black opacity-45">{state.code}</text>
          );
        })}
      </g>
      {clientPoints.map((point) => (
        <g data-client-location={point.city}>
          <title>{point.name}, {point.city}</title>
          <circle cx={point.x} cy={point.y} r="1.65" fill="#0f1114" opacity="0.1" />
          <circle cx={point.x} cy={point.y} r="0.82" fill="#0f1114" opacity="0.42" />
        </g>
      ))}
      {points.map((point) => (
        <g data-reference-location={point.displayLocation}>
          <title>{point.displayName}, {point.displayLocation}</title>
          <circle cx={point.x} cy={point.y} r="3.2" fill="#cb0000" opacity="0.14" />
          <circle cx={point.x} cy={point.y} r="1.55" fill="#cb0000" />
        </g>
      ))}
      {coveragePoints.map((point) => (
        <g data-marker="coverage" data-city={point.city}>
          <title>{point.label} Reichweitenmarker</title>
          <circle cx={point.x} cy={point.y} r="2.7" fill="#cb0000" opacity="0.08" />
          <circle cx={point.x} cy={point.y} r="1.5" fill="#ffffff" stroke="#cb0000" stroke-width="0.72" vector-effect="non-scaling-stroke" />
          <circle cx={point.x} cy={point.y} r="0.52" fill="#cb0000" />
          <text x={point.x + point.dx} y={point.y + point.dy} text-anchor={point.anchor} class="fill-[#161a20] text-[3px] font-black">{point.label}</text>
        </g>
      ))}
    </svg>
  </div>
  <div class="border-t border-hsb-line p-6 lg:p-8">
    <ul class="flex flex-wrap gap-2">
      {regions.map((region) => (
        <li class="inline-flex items-center gap-2 rounded border border-hsb-line bg-white px-2.5 py-1.5 text-xs font-bold text-hsb-steel">
          <span class="size-1.5 shrink-0 rounded-full bg-hsb-red"></span>
          {region.label}
        </li>
      ))}
    </ul>
    <div class="mt-5 grid gap-3 text-sm leading-6 text-hsb-steel">
      <p>
        Echte Deutschlandkarte mit allen 16 Bundesländern. Freigegebene Referenzen sind rot markiert, weitere Kundenstandorte dezent ergänzt.
      </p>
      <div class="flex flex-wrap gap-3 text-xs font-black uppercase tracking-[0.12em] text-hsb-steel">
        <span class="inline-flex items-center gap-2"><span class="size-2 rounded-full bg-hsb-red"></span> Freigegebene Referenz</span>
        <span class="inline-flex items-center gap-2"><span class="size-2 rounded-full bg-hsb-black/45"></span> Kundenstandort</span>
        <span class="inline-flex items-center gap-2"><span class="size-2 rounded-full border border-hsb-red bg-white"></span> Reichweitenmarker</span>
      </div>
    </div>
    <p class="mt-4 text-sm leading-6 text-hsb-steel">
      Nicht freigegebene Projekte bleiben bewusst auf Regionen beschränkt.
    </p>
    {clientPoints.length > 0 && (
      <div class="mt-6 border-t border-hsb-line pt-6">
        <p class="text-xs font-black uppercase tracking-[0.14em] text-hsb-steel">Weitere Kundenstandorte</p>
        <ul class="mt-3 grid gap-x-6 gap-y-1.5 text-sm leading-6 text-hsb-steel sm:grid-cols-2">
          {clientPoints.map((client) => (
            <li class="flex items-center gap-2">
              <span class="size-1.5 shrink-0 rounded-full bg-hsb-black/45"></span>
              <span><span class="font-bold text-hsb-black">{client.name}</span> · {client.city}</span>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</div>
