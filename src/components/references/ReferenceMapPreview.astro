---
import { clientLocations } from "../../data/clientLocations";
import { getPublicReferences } from "../../lib/content";
import ReferenceCard from "./ReferenceCard.astro";
import ReferenceMap from "./ReferenceMap.astro";

const references = getPublicReferences().slice(0, 3);
---

<section class="section border-b border-hsb-line bg-[#f8f9fb]">
  <div class="container grid gap-12 lg:grid-cols-[1.1fr_0.9fr] lg:items-start">
    <div class="relative overflow-hidden rounded-[4px] border border-hsb-line bg-white shadow-industrial">
      <div class="relative overflow-hidden bg-hsb-black p-8 text-white lg:p-12">
        <p class="eyebrow-light mb-6 flex items-center gap-2">
          <span class="size-1.5 bg-hsb-red"></span>
          Referenznetzwerk
        </p>
        <h2 class="h2 text-white [hyphens:none] [text-wrap:balance]">Geografische & technische Reichweite</h2>
        <p class="mt-6 max-w-xl text-base leading-relaxed text-white/50">
          Referenzen nur mit Kundenfreigabe – namentlich oder anonymisiert – und belastbaren Systembeschreibungen, konkret nach Herausforderung, System und Ergebnis.
          Die Übersicht zeigt, in welchen Regionen Hexagon Säurebau Kunden- und Projektstandorte dokumentiert hat.
        </p>
        <dl class="mt-10 grid gap-px overflow-hidden rounded-[2px] border border-white/10 bg-white/10 sm:grid-cols-3">
          {[
            ["Namentliche Referenzen", "7 Kunden, bundesweit"],
            ["Schwerpunkte", "Keramik · PU-Beton · Säureschutz"],
            ["Fokus", "Audit · Sanierung · Hygiene"],
          ].map(([term, value]) => (
            <div class="bg-hsb-black p-5">
              <dt class="mb-1.5 text-[0.6rem] font-black uppercase tracking-[0.2em] text-white/40">{term}</dt>
              <dd class="text-[0.85rem] font-black leading-snug text-white">{value}</dd>
            </div>
          ))}
        </dl>
      </div>
      <div class="bg-[#f1f3f6] p-1">
        <ReferenceMap references={getPublicReferences()} clients={clientLocations} />
      </div>
    </div>
    <div class="lg:pt-6">
      <div class="eyebrow mb-6 flex items-center gap-3">
        <span class="size-1.5 bg-hsb-red"></span>
        <span>Case Studies</span>
      </div>
      <h2 class="h2 [hyphens:none]">Kuratiert. Konkret. Belastbar.</h2>
      <p class="lead mt-6 text-hsb-steel/80">Jede Referenz beantwortet drei Fragen: Wo lag die Belastung, wie wurde das System geplant, und was wurde dadurch betriebsseitig besser?</p>
      <div class="mt-10 grid gap-6">
        {references.map((reference) => <ReferenceCard reference={reference} />)}
      </div>
      <div class="mt-10">
        <a class="button-secondary-dark w-full px-10 text-center lg:w-auto" href="/referenzen/">Alle Referenzen ansehen</a>
      </div>
    </div>
  </div>
</section>
