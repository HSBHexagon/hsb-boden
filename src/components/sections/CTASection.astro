---
interface Props {
  title?: string;
  text?: string;
  label?: string;
}

const {
  title = "Belastungsprofil technisch prüfen lassen",
  text = "Schicken Sie uns Branche, Fläche, Belastungen und Zeitfenster. HSB bewertet daraus den sinnvollen nächsten Schritt.",
  label = "Projekt anfragen",
} = Astro.props;
---

<section class="section-tight bg-hsb-black text-white">
  <div class="container grid gap-8 lg:grid-cols-[1.2fr_auto] lg:items-center">
    <div>
      <p class="eyebrow">Nächster Schritt</p>
      <h2 class="h2 mt-3">{title}</h2>
      <p class="lead mt-4 text-white/70">{text}</p>
    </div>
    <a class="button-primary" href="/kontakt/">{label}</a>
  </div>
</section>
