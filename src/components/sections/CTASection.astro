---
import { site } from "../../data/site";

interface Props {
  title?: string;
  text?: string;
  label?: string;
}

const {
  title = "Werksbegehung oder technische Bodenanalyse anfragen",
  text = "Hygiene- und Sicherheitscheck für Ihren Produktionsboden. HSB nimmt Belastungsprofil, Untergrund und Betriebsablauf vor Ort auf und bewertet, welcher Schritt technisch Sinn ergibt — ohne Kaufverpflichtung.",
  label = "Werksbegehung anfragen",
} = Astro.props;

const phoneHref = site.phone.replace("(0)", "").replace(/[^\d+]/g, "");
---

<section class="bg-hsb-black text-white">
  <div class="container section">
    <div class="grid gap-10 lg:grid-cols-[1fr_auto] lg:items-center">
      <div class="max-w-2xl">
        <h2 class="h2 text-white">{title}</h2>
        <p class="mt-4 text-base leading-8 text-white/60">{text}</p>
      </div>
      <div class="flex flex-col gap-3 sm:flex-row lg:flex-col xl:flex-row">
        <a class="button-primary" href="/kontakt/">{label}</a>
        <a class="button-secondary" href={`tel:${phoneHref}`} aria-label={`HSB anrufen: ${site.phone}`}>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
            <path d="M12.7 10.3c-.3-.5-2-1.4-2.4-1.6-.4-.2-.7-.2-1 .2-.2.3-.8 1-.9 1.1-.2.1-.4.1-.6 0-1-.4-2.6-1.7-3.5-3-.2-.3-.1-.5 0-.7.2-.2.5-.5.6-.7.2-.3.2-.6 0-.9-.2-.4-1-2.1-1.4-2.5C3.1 2 2.9 2 2.6 2c-.3 0-.8.2-1.1.6C1 3.2.4 4 .4 5.3c0 1.4.8 2.8 1 3 .2.3 2.1 3.3 5.1 4.7 3 1.3 3 .9 3.5.8.5-.1 1.7-.7 1.9-1.4.3-.7.3-1.2.1-1.4h-.3z" fill="currentColor"/>
          </svg>
          Direkt anrufen
        </a>
      </div>
    </div>
  </div>
</section>
