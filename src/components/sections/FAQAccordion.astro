---
interface Props {
  faqs: Array<{ question: string; answer: string }>;
}

const { faqs } = Astro.props;
---

<section class="section-tight">
  <div class="container max-w-4xl">
    <p class="eyebrow">FAQ</p>
    <h2 class="h2 mt-3">Häufige Fragen</h2>
    <div class="mt-8 divide-y divide-hsb-line rounded-lg border border-hsb-line bg-white">
      {faqs.map((faq) => (
        <details class="group p-5">
          <summary class="flex cursor-pointer list-none items-start justify-between gap-4 rounded text-base font-black transition-colors hover:text-hsb-red focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-hsb-red focus-visible:ring-offset-2">
            <span>{faq.question}</span>
            <svg
              class="mt-0.5 size-5 shrink-0 text-hsb-red transition-transform group-open:rotate-45"
              viewBox="0 0 20 20" fill="none" aria-hidden="true"
            >
              <path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </summary>
          <p class="mt-3 text-sm leading-7 text-hsb-steel">{faq.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
