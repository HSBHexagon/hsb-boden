---
import { homepageFaqs as faqs } from "../../data/homepageFaqs";
---

<section class="section bg-hsb-mist border-b border-hsb-line">
  <div class="container grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:items-start">
    <div class="lg:sticky lg:top-24">
      <p class="eyebrow">Häufige Fragen</p>
      <h2 class="h2 mt-4 max-w-sm">Was Entscheider vor der Anfrage wissen wollen</h2>
      <p class="mt-5 text-sm leading-7 text-hsb-steel max-w-xs">
        Keine Angebote ohne Grundlage, keine Systemempfehlung ohne Analyse. Das sind die meistgestellten Fragen dazu.
      </p>
      <div class="mt-8">
        <a class="button-primary" href="/kontakt/">Jetzt Ersteinschätzung anfordern</a>
      </div>
    </div>

    <div class="divide-y divide-hsb-line">
      {faqs.map((faq) => (
        <details class="group py-5">
          <summary class="flex cursor-pointer list-none items-start justify-between gap-4 text-base font-black">
            <span>{faq.question}</span>
            <svg
              class="mt-0.5 size-5 shrink-0 text-hsb-red transition-transform group-open:rotate-45"
              viewBox="0 0 20 20" fill="none" aria-hidden="true"
            >
              <path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            </svg>
          </summary>
          <p class="mt-4 text-sm leading-7 text-hsb-steel">{faq.answer}</p>
        </details>
      ))}
    </div>
  </div>
</section>
