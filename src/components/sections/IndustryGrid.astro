---
import { getIndustries } from "../../lib/content";

const industries = getIndustries();
---

<section class="section bg-hsb-mist">
  <div class="container">
    <div class="mb-10 max-w-3xl">
      <p class="eyebrow">Branchen</p>
      <h2 class="h2 mt-3">Jede Produktion hat ein eigenes Belastungsprofil</h2>
      <p class="lead mt-4">Die neue HSB-Struktur schafft eigene Einstiegspunkte für Suchanfragen aus Lebensmittel, Molkerei, Getränke, Chemie, Pharma und Großküchen.</p>
    </div>
    <div class="grid-auto">
      {industries.map((industry) => (
        <a class="surface p-6 no-underline" href={`/branchen/${industry.slug}/`}>
          <h3 class="h3">{industry.title}</h3>
          <p class="mt-3 text-sm leading-7 text-hsb-steel">{industry.searchIntent}</p>
          <span class="mt-5 inline-block text-sm font-black text-hsb-red">{industry.ctaLabel}</span>
        </a>
      ))}
    </div>
  </div>
</section>
