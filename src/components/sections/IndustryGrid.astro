---
import { getIndustries } from "../../lib/content";

const industries = getIndustries();
---

<section class="section bg-hsb-mist border-b border-hsb-line">
  <div class="container">
    <div class="mb-12 max-w-2xl">
      <p class="eyebrow mb-4">Branchenfokus</p>
      <h2 class="h2">Jede Produktion hat ein anderes Belastungsprofil</h2>
      <p class="lead mt-4">HSB kennt die unterschiedlichen Anforderungen aus Lebensmittel, Molkerei, Getränke, Chemie, Pharma und Großküchen.</p>
    </div>

    <!-- Asymmetric: first one large, rest grid -->
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {industries.map((industry, i) => (
        <a
          href={`/branchen/${industry.slug}/`}
          class={[
            "group flex flex-col justify-between gap-8 rounded-[4px] border no-underline transition hover:-translate-y-0.5",
            i === 0
              ? "border-hsb-red/25 bg-white p-8 text-hsb-black shadow-industrial sm:col-span-2 lg:col-span-1"
              : "border-hsb-line bg-white p-6 hover:shadow-industrial",
          ].join(" ")}
        >
          <div>
            {i === 0 ? <p class="mb-3 text-[0.65rem] font-black uppercase tracking-[0.18em] text-hsb-red">Schwerpunkt</p> : null}
            <h3 class="h3 transition-colors group-hover:text-hsb-red">{industry.title}</h3>
            <p class="mt-3 text-sm leading-7 text-hsb-steel">
              {industry.searchIntent}
            </p>
          </div>
          <span class="inline-flex items-center gap-2 text-sm font-bold text-hsb-red">
            {industry.ctaLabel}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
              <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
