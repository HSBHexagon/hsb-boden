---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { homeAlternates, landing, type Lang } from "../../lib/i18n";
import { site } from "../../data/site";

interface Props {
  lang: Exclude<Lang, "de">;
}

const { lang } = Astro.props;
const t = landing[lang];
const path = `/${lang}/`;
const phoneHref = `tel:${site.phone.replace(/[^+\d]/g, "")}`;
---

<BaseLayout title={t.meta.seoTitle} description={t.meta.description} path={path} lang={lang} alternates={homeAlternates}>
  <section class="section bg-hsb-mist">
    <div class="container max-w-5xl">
      <p class="eyebrow">{t.hero.eyebrow}</p>
      <h1 class="h1 mt-4">{t.hero.h1}</h1>
      <p class="lead mt-6 max-w-3xl">{t.hero.text}</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a class="button-primary" href="#contact">{t.hero.ctaContact}</a>
        <a class="button-secondary-dark" href="/">{t.hero.ctaGerman}</a>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="h2">{t.systems.title}</h2>
      <p class="lead mt-4 max-w-3xl">{t.systems.intro}</p>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {t.systems.items.map((item) => (
          <article class="surface p-6">
            <h3 class="h3">{item.title}</h3>
            <p class="mt-3 text-sm leading-6 text-hsb-steel">{item.text}</p>
          </article>
        ))}
      </div>
      <p class="mt-6 text-sm text-hsb-steel">{t.germanNote}</p>
    </div>
  </section>

  <section class="section bg-hsb-mist">
    <div class="container grid gap-10 lg:grid-cols-2 lg:items-start">
      <div>
        <h2 class="h2">{t.industries.title}</h2>
        <p class="lead mt-4">{t.industries.intro}</p>
        <ul class="mt-6 grid gap-3 sm:grid-cols-2">
          {t.industries.items.map((item) => (
            <li class="rounded border border-hsb-line bg-white px-4 py-3 text-sm font-bold text-hsb-black">{item}</li>
          ))}
        </ul>
      </div>
      <div class="rounded-[10px] bg-hsb-black p-8 text-white lg:p-10">
        <p class="eyebrow-light">{t.reference.title}</p>
        <h2 class="h2 mt-4 text-white">{t.reference.name}</h2>
        <p class="mt-5 text-sm leading-7 text-white/70">{t.reference.text}</p>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="h2">{t.process.title}</h2>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {t.process.steps.map((step, index) => (
          <article class="surface p-6">
            <p class="text-xs font-black uppercase tracking-wide text-hsb-red">0{index + 1}</p>
            <h3 class="h3 mt-2">{step.title}</h3>
            <p class="mt-3 text-sm leading-6 text-hsb-steel">{step.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="contact" class="section bg-hsb-black text-white">
    <div class="container max-w-4xl">
      <h2 class="h2 text-white">{t.contact.title}</h2>
      <p class="mt-4 max-w-2xl text-base leading-7 text-white/70">{t.contact.text}</p>
      <div class="mt-8 grid gap-4 sm:grid-cols-2">
        <a class="rounded border border-white/15 p-6 no-underline transition-colors hover:border-white/40" href={phoneHref}>
          <p class="text-xs font-black uppercase tracking-wide text-white/60">{t.contact.phoneLabel}</p>
          <p class="mt-2 text-lg font-black text-white">{site.phone}</p>
        </a>
        <a class="rounded border border-white/15 p-6 no-underline transition-colors hover:border-white/40" href={`mailto:${site.email}`}>
          <p class="text-xs font-black uppercase tracking-wide text-white/60">{t.contact.emailLabel}</p>
          <p class="mt-2 text-lg font-black text-white">{site.email}</p>
        </a>
      </div>
      <p class="mt-6 text-sm text-white/60">{t.contact.languagesNote}</p>
    </div>
  </section>
</BaseLayout>
