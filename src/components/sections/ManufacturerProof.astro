---
import { manufacturers } from "../../data/manufacturers";
---

<section class="section">
  <div class="container grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
    <div>
      <p class="eyebrow">Hersteller- und Fachquellen</p>
      <h2 class="h2 mt-3">Bewährte Systembasis sauber eingeordnet</h2>
      <p class="lead mt-4">Argelith und Zahna werden als technische Informations- und Herstellerquellen genutzt. Die Webseite behauptet keine Partnerschaft oder Zertifizierung, wenn diese nicht belegbar freigegeben ist.</p>
    </div>
    <div class="grid gap-4">
      {manufacturers.map((manufacturer) => (
        <article class="surface p-6">
          <h3 class="h3">{manufacturer.name}</h3>
          <p class="mt-2 text-sm font-bold text-hsb-steel">{manufacturer.role}</p>
          <ul class="mt-4 space-y-2 text-sm leading-6 text-hsb-steel">
            {manufacturer.proofPoints.map((point) => <li>• {point}</li>)}
          </ul>
          <div class="mt-5 flex flex-wrap gap-3">
            {manufacturer.links.map((link) => <a class="text-sm font-black text-hsb-red" href={link.href}>{link.label}</a>)}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
