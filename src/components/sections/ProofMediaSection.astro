---
const mediaPanels = [
  {
    image: "/media/hsb/projekte/keramik-halle-rinnen.webp",
    alt: "Neu verlegter keramischer Industrieboden mit Sechskantfliesen und zwei integrierten Entwässerungsrinnen in einer Produktionshalle",
    eyebrow: "Keramischer Industrieboden",
    title: "Hygienische Verfliesung für Lebensmittel- und Produktionsbereiche",
    text:
      "Sechskant-Keramik mit Gefälle und integrierten Rinnenläufen, verlegt in einer neuen Produktionshalle. Ausgelegt für die Hygieneanforderungen von Lebensmittelbetrieben.",
    tone: "dark",
  },
  {
    image: "/media/hsb/projekte/hexagon-rinne-detail.webp",
    alt: "Detailaufnahme einer Edelstahl-Entwässerungsrinne mit Rost, eingefasst in Sechskant-Keramikfliesen",
    eyebrow: "Entwässerung & Anschluss",
    title: "Entwässerung ist Teil des Bodensystems",
    text:
      "Gefälle, Rinnenkante, Fliesenbild und Anschlussdetails entscheiden darüber, ob Flächen dauerhaft reinigbar bleiben und Audits standhalten.",
    tone: "light",
  },
  {
    image: "/media/hsb/projekte/beschichtete-halle.webp",
    alt: "Frisch beschichteter, glänzender Industrieboden in einer Logistik- und Produktionshalle mit Stahlbau",
    eyebrow: "Beschichtung & Sanierung",
    title: "Oberflächen nach Belastungsprofil, nicht nach Standard",
    text:
      "Bei Beschichtung und Sanierung zählt nicht nur das Material. Auch Sperrzeit, Untergrundzustand, Rutschhemmung und Wiederinbetriebnahme müssen von Anfang an geplant werden.",
    tone: "light",
  },
  {
    image: "/media/hsb/projekte/chemie-anlage-keramik.webp",
    alt: "Chemieresistenter Industrieboden unter einer Produktionsanlage in der Chemieindustrie",
    eyebrow: "Säureschutz & Chemie",
    title: "Beständigkeit gegen aggressive Medien",
    text:
      "Spezialkeramik und säurefeste Verfugung schützen die Bausubstanz dauerhaft vor chemischen Angriffen und erfüllen WHG-Anforderungen.",
    tone: "light",
  },
  {
    image: "/media/hsb/projekte/pharma-halle-keramik.webp",
    alt: "Helle, hygienische Produktionshalle mit Sechskant-Keramikboden für die Pharmaindustrie",
    eyebrow: "Pharma & Hygiene",
    title: "Maximale Reinigbarkeit für sensible Zonen",
    text:
      "Porenfreie Oberflächen und präzise Gefälleplanung verhindern stehendes Wasser und Keimbildung in pharmazeutischen Reinräumen.",
    tone: "light",
  },
];
---

<section class="section border-b border-hsb-line">
  <div class="container">
    <div class="mb-12 grid gap-6 lg:grid-cols-[1fr_auto] lg:items-end">
      <div class="max-w-3xl">
        <p class="eyebrow">Ausgeführte Referenzen</p>
        <h2 class="h2 mt-4">Vertrauen durch sichtbare Ausführungsqualität</h2>
        <p class="lead mt-4">
          Keine Stockfotos, sondern reale Industrieboden-Flächen aus dem HSB-Arbeitsumfeld.
        </p>
      </div>
      <a class="button-secondary-dark shrink-0" href="/referenzen/">Alle Referenzen ansehen</a>
    </div>

    <div class="grid gap-5 lg:grid-cols-[1.35fr_0.65fr] lg:items-stretch">
      {mediaPanels.slice(0, 1).map((panel) => (
        <article class:list={[
          "overflow-hidden rounded-[8px] border",
          panel.tone === "dark" ? "border-hsb-black bg-hsb-black text-white" : "border-hsb-line bg-white text-hsb-black",
        ]}>
          <div class:list={["aspect-[16/10] overflow-hidden border-b lg:aspect-[16/9]", panel.tone === "dark" ? "border-white/10" : "border-hsb-line"]}>
            <img
              src={panel.image}
              alt={panel.alt}
              class="h-full w-full object-cover object-center transition-transform duration-500 hover:scale-[1.015]"
              loading="lazy"
              width="554"
              height="361"
            />
          </div>
          <div class="grid gap-3 p-6 lg:p-8">
            <p class:list={["text-xs font-bold uppercase tracking-[0.16em]", panel.tone === "dark" ? "text-white/72" : "text-hsb-red"]}>
              {panel.eyebrow}
            </p>
            <h3 class:list={["h3", panel.tone === "dark" ? "text-white" : "text-hsb-black"]}>{panel.title}</h3>
            <p class:list={["text-sm leading-7", panel.tone === "dark" ? "text-white/65" : "text-hsb-steel"]}>{panel.text}</p>
          </div>
        </article>
      ))}
      <div class="grid gap-5">
        {mediaPanels.slice(1).map((panel) => (
          <article class="grid overflow-hidden rounded-[8px] border border-hsb-line bg-white text-hsb-black sm:grid-cols-[190px_1fr] lg:grid-cols-1">
            <div class="aspect-[4/3] overflow-hidden border-b border-hsb-line sm:aspect-auto sm:border-b-0 sm:border-r lg:aspect-[4/3] lg:border-b lg:border-r-0">
              <img
                src={panel.image}
                alt={panel.alt}
                class="h-full w-full object-cover object-center transition-transform duration-500 hover:scale-[1.015]"
                loading="lazy"
                width="562"
                height="369"
              />
            </div>
            <div class="grid gap-2 p-5">
              <p class="text-xs font-bold uppercase tracking-[0.14em] text-hsb-red">{panel.eyebrow}</p>
              <h3 class="text-lg font-black leading-tight text-hsb-black">{panel.title}</h3>
              <p class="text-sm leading-6 text-hsb-steel">{panel.text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>
