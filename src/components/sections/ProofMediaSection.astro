---
const mediaPanels = [
  {
    image: "/media/hsb/current/referenzflaeche-1.png",
    alt: "Keramischer Industrieboden mit Entwässerungsrinne — Referenzfläche Hexagon Säurebau",
    eyebrow: "Keramischer Industrieboden",
    title: "Hygienische Verfliesung für Lebensmittel- und Produktionsbereiche",
    text:
      "Fugenarme keramische Systeme mit Gefälle, Rinnenkante und Säureschutzbeschichtung — ausgelegt für die Hygieneanforderungen von Lebensmittelbetrieben.",
    tone: "dark",
  },
  {
    image: "/media/hsb/current/referenzflaeche-2.png",
    alt: "Hygienische Industrieverfliesung für Produktionsbereich — Hexagon Säurebau",
    eyebrow: "Beschichtung & Sanierung",
    title: "Oberflächen nach Belastungsprofil, nicht nach Standard",
    text:
      "Bei Sanierungen zählt nicht nur das Material — auch Sperrzeit, Untergrundzustand, Rutschhemmung und Wiederinbetriebnahme müssen von Anfang an geplant werden.",
    tone: "light",
  },
  {
    image: "/media/hsb/current/referenzflaeche-3.png",
    alt: "Säurebeständige Bodenfläche in Industrieumgebung — Hexagon Säurebau Ausführung",
    eyebrow: "Entwässerung & Anschluss",
    title: "Entwässerung ist Teil des Bodensystems",
    text:
      "Gefälle, Rinnenkante, Fliesenbild und Anschlussdetails entscheiden darüber, ob Flächen dauerhaft reinigbar bleiben und Audits standhalten.",
    tone: "light",
  },
];
---

<section class="section border-b border-hsb-line">
  <div class="container">
    <div class="mb-12 grid gap-6 lg:grid-cols-[1fr_auto] lg:items-end">
      <div class="max-w-3xl">
        <p class="eyebrow">Ausgeführte Referenzen</p>
        <h2 class="h2 mt-4">Vertrauen durch sichtbare Ausführungsqualität</h2>
        <p class="lead mt-4">
          Keine Stockfotos, sondern reale Industrieboden-Flächen aus dem HSB-Arbeitsumfeld.
        </p>
      </div>
      <a class="button-secondary-dark shrink-0" href="/referenzen/">Alle Referenzen ansehen</a>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
      {mediaPanels.map((panel) => (
        <article class:list={[
          "overflow-hidden rounded-[10px] border",
          panel.tone === "dark" ? "border-hsb-black bg-hsb-black text-white" : "border-hsb-line bg-white text-hsb-black",
        ]}>
          <div class:list={["aspect-[4/3] overflow-hidden border-b", panel.tone === "dark" ? "border-white/10" : "border-hsb-line"]}>
            <img
              src={panel.image}
              alt={panel.alt}
              class="h-full w-full object-cover object-center transition-transform duration-500 hover:scale-[1.025]"
              loading="lazy"
              width="480"
              height="360"
            />
          </div>
          <div class="grid gap-3 p-6">
            <p class:list={["text-xs font-bold uppercase tracking-[0.16em]", panel.tone === "dark" ? "text-white/45" : "text-hsb-red"]}>
              {panel.eyebrow}
            </p>
            <h3 class:list={["h3", panel.tone === "dark" ? "text-white" : "text-hsb-black"]}>{panel.title}</h3>
            <p class:list={["text-sm leading-7", panel.tone === "dark" ? "text-white/65" : "text-hsb-steel"]}>{panel.text}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
