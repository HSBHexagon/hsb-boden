---
const mediaPanels = [
  {
    image: "/media/hsb/current/referenzflaeche-1.webp",
    alt: "Keramischer Industrieboden mit Entwässerungsrinne als Referenzfläche von Hexagon Säurebau",
    eyebrow: "Keramischer Industrieboden",
    title: "Hygienische Verfliesung für Lebensmittel- und Produktionsbereiche",
    text:
      "Fugenarme keramische Systeme mit Gefälle, Rinnenkante und Säureschutzbeschichtung. Ausgelegt für die Hygieneanforderungen von Lebensmittelbetrieben.",
    tone: "dark",
  },
  {
    image: "/media/hsb/current/referenzflaeche-2.webp",
    alt: "Hygienische Industrieverfliesung für einen Produktionsbereich von Hexagon Säurebau",
    eyebrow: "Beschichtung & Sanierung",
    title: "Oberflächen nach Belastungsprofil, nicht nach Standard",
    text:
      "Bei Sanierungen zählt nicht nur das Material. Auch Sperrzeit, Untergrundzustand, Rutschhemmung und Wiederinbetriebnahme müssen von Anfang an geplant werden.",
    tone: "light",
  },
  {
    image: "/media/hsb/current/referenzflaeche-3.webp",
    alt: "Säurebeständige Bodenfläche in Industrieumgebung als Ausführung von Hexagon Säurebau",
    eyebrow: "Entwässerung & Anschluss",
    title: "Entwässerung ist Teil des Bodensystems",
    text:
      "Gefälle, Rinnenkante, Fliesenbild und Anschlussdetails entscheiden darüber, ob Flächen dauerhaft reinigbar bleiben und Audits standhalten.",
    tone: "light",
  },
];
---

<section class="section border-b border-hsb-line bg-white">
  <div class="container">
    <div class="mb-16 max-w-4xl">
      <div class="flex items-center gap-3 eyebrow mb-6">
        <span class="size-2 bg-hsb-red"></span>
        <span>Ausführung im Bild</span>
      </div>
      <h2 class="h2">Reale Flächen, saubere Details, nachvollziehbare Systeme</h2>
      <p class="lead mt-8 max-w-2xl text-hsb-steel/80">
        Jedes Bild zeigt eine reale Industrieboden-Fläche aus dem HSB-Arbeitsumfeld. Relevant sind hier nicht Effekte, sondern Verfliesung, Entwässerung, Anschlussdetails und Reinigbarkeit.
      </p>
    </div>

    <div class="grid gap-8 lg:grid-cols-[1.4fr_0.6fr]">
      {mediaPanels.slice(0, 1).map((panel) => (
        <article class="group relative overflow-hidden rounded-[4px] border border-hsb-line bg-hsb-black text-white shadow-industrial lg:min-h-[600px]">
          <div class="absolute inset-0 overflow-hidden">
            <img
              src={panel.image}
              alt={panel.alt}
              class="h-full w-full object-cover object-center transition-transform ease-out group-hover:scale-105"
              style="transition-duration: 1500ms"
              loading="lazy"
              width="1024"
              height="640"
            />
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-black via-black/30 to-transparent"></div>
          <div class="relative z-10 flex h-full flex-col justify-end p-8 lg:p-12">
            <p class="text-xs font-black uppercase tracking-[0.2em] text-hsb-red mb-4">{panel.eyebrow}</p>
            <h3 class="max-w-2xl text-2xl font-black leading-tight text-white lg:text-[2rem]">{panel.title}</h3>
            <div class="mt-6 h-px w-24 bg-hsb-red/50"></div>
            <p class="mt-6 max-w-xl text-sm lg:text-base leading-relaxed text-white/60">{panel.text}</p>
          </div>
        </article>
      ))}
      <div class="grid gap-8">
        {mediaPanels.slice(1).map((panel) => (
          <article class="group relative flex flex-col overflow-hidden rounded-[4px] border border-hsb-line bg-white text-hsb-black">
            <div class="aspect-[16/10] overflow-hidden border-b border-hsb-line">
              <img
                src={panel.image}
                alt={panel.alt}
                class="h-full w-full object-cover object-center transition-transform duration-1000 group-hover:scale-105"
                loading="lazy"
                width="562"
                height="351"
              />
            </div>
            <div class="p-6 lg:p-8">
              <p class="text-[0.65rem] font-black uppercase tracking-[0.18em] text-hsb-red mb-3">{panel.eyebrow}</p>
              <h3 class="text-xl font-black leading-tight text-hsb-black group-hover:text-hsb-red transition-colors">{panel.title}</h3>
              <p class="mt-4 text-sm leading-7 text-hsb-steel">{panel.text}</p>
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="mt-12 flex justify-center lg:justify-start">
      <a class="button-secondary-dark px-12" href="/referenzen/">Mehr Referenzen ansehen</a>
    </div>
  </div>
</section>
