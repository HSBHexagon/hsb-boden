---
const problems = [
  {
    number: "01",
    title: "Thermoschock-Schäden",
    text: "Differenzialausdehnung zwischen Beton und Belag bei Heißwasserreinigung (CIP). Starre Standardbeläge reißen ab oder bilden Blasen.",
    consequence: "Folge: Unterläufigkeit, Zerstörung des Haftverbunds und massive Sanierungskosten nach kurzer Laufzeit.",
  },
  {
    number: "02",
    title: "Chemische Korrosion der Fuge",
    text: "Milchsäure, Fruchtsäuren oder aggressive Reinigungsmittel zersetzen zementöse Fugen. Feuchtigkeit dringt bis zur Abdichtungsebene vor.",
    consequence: "Folge: Mikrobielle Belastung in Hohlstellen (Keimnester), Audit-Mängel und Risiko für die Produktsicherheit.",
  },
  {
    number: "03",
    title: "Mangelhafte Entwässerung",
    text: "Unzureichendes Gefälle (< 1,5%) führt zu stehendem Wasser. Edelstahlrinnen ohne Flansch-System bilden undichte Übergänge.",
    consequence: "Folge: Rutschunfälle, stehende Chemie-Konzentrationen und schnelleres Versagen der umliegenden Fugen.",
  },
  {
    number: "04",
    title: "Ungeplante Stillstandszeiten",
    text: "Bodenschäden werden oft erst bei Audits oder Totalausfall adressiert. Not-Reparaturen ohne Bauabschnitt-Planung stoppen die Produktion.",
    consequence: "Folge: Lieferverzug, Pönalen und enorme wirtschaftliche Einbußen durch Produktionsausfall.",
  },
];
---

<section class="section border-b border-hsb-line bg-hsb-black text-white">
  <div class="container">
    <div class="mb-14 grid gap-4 lg:grid-cols-[1fr_auto] lg:items-end">
      <div>
        <p class="eyebrow-light">Technische Schwachstellen</p>
        <h2 class="h2 mt-4 max-w-2xl text-white">
          Warum Industrieböden in der<br class="hidden lg:block" />
          Produktion wirklich versagen
        </h2>
      </div>
      <p class="max-w-xs text-sm leading-7 text-white/72 lg:text-right">
        Nicht das Material ist das Problem, sondern die Lücke zwischen Belastungsprofil und technischer Planung.
      </p>
    </div>

    <div class="grid gap-px border border-white/5 bg-white/5 sm:grid-cols-2">
      {problems.map((item, i) => (
        <article class="reveal flex flex-col gap-6 bg-hsb-black p-8 lg:p-10" style={`--reveal-delay:${i * 60}ms`}>
          <div class="flex items-center gap-4">
            <span class="rounded-[2px] border border-white/10 px-2.5 py-1 font-mono text-[0.65rem] font-black uppercase tracking-[0.2em] text-white/52">
              Analyse {item.number}
            </span>
          </div>
          <div>
            <h3 class="h3 leading-tight text-white">{item.title}</h3>
            <p class="mt-4 text-[0.925rem] leading-7 text-white/54">{item.text}</p>
          </div>
          <div class="mt-auto pt-6">
            <p class="flex items-start gap-2 text-[0.8rem] font-bold leading-6 text-hsb-red-light">
              <span class="mt-1 size-1.5 shrink-0 bg-hsb-red"></span>
              <span>{item.consequence}</span>
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
