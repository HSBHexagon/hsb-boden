---
import { getServices } from "../../lib/content";

const services = getServices();
---

<section class="section">
  <div class="container">
    <div class="mb-10 max-w-3xl">
      <p class="eyebrow">Leistungen</p>
      <h2 class="h2 mt-3">Systeme für belastete Produktionsflächen</h2>
      <p class="lead mt-4">HSB plant nicht nur die Oberfläche, sondern den vollständigen Aufbau aus Untergrund, Belag, Fuge, Abdichtung, Entwässerung und Sanierungslogik.</p>
    </div>
    <div class="grid-auto">
      {services.map((service) => (
        <a class="surface p-6 no-underline transition hover:-translate-y-1 hover:shadow-industrial" href={`/leistungen/${service.slug}/`}>
          <h3 class="h3">{service.title}</h3>
          <p class="mt-3 text-sm leading-7 text-hsb-steel">{service.problem}</p>
          <span class="mt-5 inline-block text-sm font-black text-hsb-red">{service.ctaLabel}</span>
        </a>
      ))}
    </div>
  </div>
</section>
