---
import { getServices } from "../../lib/content";

const services = getServices();
---

<section class="section border-b border-hsb-line">
  <div class="container">
    <div class="mb-12 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div class="max-w-2xl">
        <p class="eyebrow mb-4">Systeme & Detailpunkte</p>
        <h2 class="h2">Systeme für belastete Produktionsflächen</h2>
      </div>
      <p class="text-sm font-bold text-hsb-steel sm:text-right">
        Keramik · PU-Beton · Entwässerung · Abdichtung
      </p>
    </div>

    <!-- Two-column grid: large feature + list -->
    <div class="grid gap-4 lg:grid-cols-[1fr_1fr]">

      <!-- Featured: first 2 services large -->
      <div class="flex flex-col gap-4">
        {services.slice(0, 2).map((service) => (
          <a
            href={`/leistungen/${service.slug}/`}
            class="group flex flex-col justify-between gap-6 rounded-[4px] border border-hsb-line bg-white p-8 text-hsb-black no-underline transition hover:-translate-y-0.5 hover:shadow-industrial"
          >
            <div>
              <div class="mb-3 flex items-center gap-2">
                <span class="size-1 bg-hsb-red"></span>
                <p class="text-[0.65rem] font-black uppercase tracking-[0.18em] text-hsb-red">Leistung</p>
              </div>
              <h3 class="h3 transition-colors group-hover:text-hsb-red">{service.title}</h3>
              <p class="mt-3 text-sm leading-7 text-hsb-steel">{service.problem}</p>
            </div>
            <span class="inline-flex items-center gap-2 text-sm font-bold text-hsb-red">
              {service.ctaLabel}
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2 7h10M8 3l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        ))}
      </div>

      <!-- Right: remaining 6 as compact list -->
      <div class="flex flex-col divide-y divide-hsb-line rounded-[4px] border border-hsb-line">
        {services.slice(2).map((service) => (
          <a
            href={`/leistungen/${service.slug}/`}
            class="group flex items-center justify-between gap-4 px-6 py-5 no-underline transition hover:bg-hsb-mist"
          >
            <div>
              <p class="font-bold group-hover:text-hsb-red transition-colors">{service.title}</p>
              <p class="mt-0.5 text-xs text-hsb-steel line-clamp-1">{service.ctaLabel}</p>
            </div>
            <svg class="shrink-0 text-hsb-line group-hover:text-hsb-red transition-colors" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        ))}
      </div>

    </div>
  </div>
</section>
