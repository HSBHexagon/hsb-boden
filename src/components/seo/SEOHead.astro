---
import { canonical, pageTitle } from "../../lib/seo";
import { buildOrganizationJsonLd } from "../../lib/schema";

interface Props {
  title?: string;
  description?: string;
  path?: string;
  jsonLd?: unknown[];
  alternates?: { lang: string; path: string }[];
}

const { title, description, path = "/", jsonLd = [], alternates = [] } = Astro.props;
const allJsonLd = [buildOrganizationJsonLd(), ...jsonLd];
---

<title>{pageTitle(title)}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonical(path)} />
{alternates.map((alt) => <link rel="alternate" hreflang={alt.lang} href={canonical(alt.path)} />)}
{alternates.length > 0 && <link rel="alternate" hreflang="x-default" href={canonical(alternates.find((alt) => alt.lang === "de")?.path ?? "/")} />}
<link rel="icon" href="/brand/hsb-hexagon-mark.svg" type="image/svg+xml" />
<link rel="alternate icon" href="/brand/hsb-boden-logo.png" type="image/png" />
<link rel="apple-touch-icon" href="/brand/hsb-boden-logo.png" />
<meta property="og:type" content="website" />
<meta property="og:title" content={pageTitle(title)} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonical(path)} />
<meta property="og:site_name" content="HSB Hexagon Säurebau" />
<meta property="og:image" content={`${canonical("/")}brand/og-image.png`} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta name="twitter:card" content="summary_large_image" />
{allJsonLd.map((item) => <script is:inline type="application/ld+json" set:html={JSON.stringify(item).replace(/</g, '\\u003c').replace(/>/g, '\\u003e')} />)}
