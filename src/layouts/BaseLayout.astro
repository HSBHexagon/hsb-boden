---
import CookieConsent from "../components/layout/CookieConsent.astro";
import Footer from "../components/layout/Footer.astro";
import Header from "../components/layout/Header.astro";
import LanguageSuggest from "../components/layout/LanguageSuggest.astro";
import SEOHead from "../components/seo/SEOHead.astro";
import { ui, type Lang } from "../lib/i18n";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  path: string;
  jsonLd?: unknown[];
  lang?: Lang;
  alternates?: { lang: string; path: string }[];
}

const { title, description, path, jsonLd = [], lang = "de", alternates = [] } = Astro.props;
const skipLabel = ui[lang].skip;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEOHead title={title} description={description} path={path} jsonLd={jsonLd} alternates={alternates} />
    {import.meta.env.PUBLIC_GTM_ID && (
      <script is:inline define:vars={{ gtmId: import.meta.env.PUBLIC_GTM_ID }}>
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer',gtmId);
      </script>
    )}
  </head>
  <body>
    {import.meta.env.PUBLIC_GTM_ID && (
      <noscript>
        <iframe src={`https://www.googletagmanager.com/ns.html?id=${import.meta.env.PUBLIC_GTM_ID}`} height="0" width="0" style="display:none;visibility:hidden"></iframe>
      </noscript>
    )}
    <a class="skip-link" href="#main">{skipLabel}</a>
    <Header lang={lang} />
    <LanguageSuggest lang={lang} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
    <CookieConsent lang={lang} />
    <script>
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const els = document.querySelectorAll(".reveal");
      if (reduce || !("IntersectionObserver" in window)) {
        els.forEach((el) => el.classList.add("is-visible"));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.12 },
        );
        els.forEach((el) => io.observe(el));
      }

      // HSB Tracking Bridge
      window.addEventListener("hsb:tracking", (e: any) => {
        const detail = e.detail;
        const dataLayer = (window as any).dataLayer || [];
        dataLayer.push({
          event: detail.event,
          ...detail,
        });
        if (import.meta.env.DEV) {
          console.log("[HSB Tracking]", detail);
        }
      });
    </script>
  </body>
</html>
