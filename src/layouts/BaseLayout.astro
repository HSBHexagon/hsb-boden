---
import CookieConsent from "../components/layout/CookieConsent.astro";
import Footer from "../components/layout/Footer.astro";
import Header from "../components/layout/Header.astro";
import LanguageSuggest from "../components/layout/LanguageSuggest.astro";
import SEOHead from "../components/seo/SEOHead.astro";
import { ui, type Lang } from "../lib/i18n";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  path: string;
  jsonLd?: unknown[];
  lang?: Lang;
  alternates?: { lang: string; path: string }[];
}

const { title, description, path, jsonLd = [], lang = "de", alternates = [] } = Astro.props;
const skipLabel = ui[lang].skip;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEOHead title={title} description={description} path={path} jsonLd={jsonLd} alternates={alternates} />
    <meta name="google-site-verification" content="5ZDng3SGpGY35eGmYVqaAtJLSlOiVRVdN9f1zLr8f0s" />
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-VC4BJBEFTV"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){window.dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-VC4BJBEFTV');
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">{skipLabel}</a>
    <Header lang={lang} />
    <LanguageSuggest lang={lang} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
    <CookieConsent lang={lang} />
    <script>
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const els = document.querySelectorAll(".reveal");
      if (reduce || !("IntersectionObserver" in window)) {
        els.forEach((el) => el.classList.add("is-visible"));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.12 },
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
  </body>
</html>
