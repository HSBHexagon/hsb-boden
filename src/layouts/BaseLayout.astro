---
import CookieConsent from "../components/layout/CookieConsent.astro";
import Footer from "../components/layout/Footer.astro";
import Header from "../components/layout/Header.astro";
import LanguageSuggest from "../components/layout/LanguageSuggest.astro";
import SEOHead from "../components/seo/SEOHead.astro";
import { ui, type Lang } from "../lib/i18n";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  path: string;
  jsonLd?: unknown[];
  lang?: Lang;
  alternates?: { lang: string; path: string }[];
  robots?: string;
}

const { title, description, path, jsonLd = [], lang = "de", alternates = [], robots } = Astro.props;
const skipLabel = ui[lang].skip;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEOHead title={title} description={description} path={path} jsonLd={jsonLd} alternates={alternates} robots={robots} />
    <!-- GA4 Basic Consent: Der externe Google-Request entsteht erst nach einer
         aktiven Statistik-Einwilligung. Der Loader reagiert auf hsb:consent. -->
    <script>
      import { initializeAnalytics } from "../lib/analytics";

      initializeAnalytics();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">{skipLabel}</a>
    <Header lang={lang} />
    <LanguageSuggest lang={lang} />
    <main id="main">
      <slot />
    </main>
    <Footer lang={lang} />
    <CookieConsent lang={lang} />
    <script>
      const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const els = document.querySelectorAll(".reveal");
      if (reduce || !("IntersectionObserver" in window)) {
        els.forEach((el) => el.classList.add("is-visible"));
      } else {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { rootMargin: "0px 0px -8% 0px", threshold: 0.12 },
        );
        els.forEach((el) => io.observe(el));
      }
    </script>
    <script>
      import { captureAttribution, updateSessionAttribution } from "../lib/attribution";

      // Erst-Attribution der Session (UTM/Referrer/Landingpage) erfassen,
      // damit sie beim MPA-Seitenwechsel bis zum Lead-Formular erhalten bleibt.
      try {
        const current = captureAttribution({
          search: window.location.search,
          referrer: document.referrer,
          pathname: window.location.pathname,
          origin: window.location.origin,
        });
        updateSessionAttribution(window.sessionStorage, current);
      } catch {
        // Attribution ist optional — Seitenfunktion darf nie daran scheitern.
      }
    </script>
  </body>
</html>
