---
import ReferenceCard from "../../components/references/ReferenceCard.astro";
import CTASection from "../../components/sections/CTASection.astro";
import FAQAccordion from "../../components/sections/FAQAccordion.astro";
import PageHero from "../../components/sections/PageHero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getIndustries, getReferencesForSlugs, getServices } from "../../lib/content";
import { buildBreadcrumbJsonLd, buildFaqJsonLd } from "../../lib/schema";

export const prerender = true;

export function getStaticPaths() {
  return getIndustries().map((industry) => ({
    params: { slug: industry.slug },
    props: { industry },
  }));
}

const { industry } = Astro.props;
const services = getServices().filter((service) => industry.relatedServices.includes(service.slug));
const relatedReferences = getReferencesForSlugs(industry.relatedReferences);
const path = `/branchen/${industry.slug}/`;
---

<BaseLayout title={industry.seoTitle} description={industry.description} path={path} jsonLd={[buildFaqJsonLd(industry.faqs), buildBreadcrumbJsonLd([{ name: "Start", path: "/" }, { name: "Branchen", path: "/branchen/" }, { name: industry.title, path }])]}>
  <PageHero eyebrow="Branche" title={industry.h1} text={industry.description} ctaLabel={industry.ctaLabel} />
  <section class="section">
    <div class="container grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="eyebrow">Suchintention</p>
        <h2 class="h2 mt-3">Was Entscheider hier wirklich suchen</h2>
        <p class="lead mt-4">{industry.searchIntent}</p>
      </div>
      <div class="grid gap-4">
        <article class="surface p-6">
          <h3 class="h3">Typische Probleme</h3>
          <div class="mt-4 flex flex-wrap gap-2">
            {industry.typicalProblems.map((item) => <span class="rounded bg-hsb-mist px-3 py-2 text-sm font-bold text-hsb-steel">{item}</span>)}
          </div>
        </article>
        <article class="surface p-6">
          <h3 class="h3">Bodenanforderungen</h3>
          <div class="mt-4 flex flex-wrap gap-2">
            {industry.floorRequirements.map((item) => <span class="rounded bg-hsb-mist px-3 py-2 text-sm font-bold text-hsb-steel">{item}</span>)}
          </div>
        </article>
      </div>
    </div>
  </section>
  <section class="section-tight bg-hsb-mist">
    <div class="container">
      <p class="eyebrow">Passende Systeme</p>
      <h2 class="h2 mt-3">Empfohlene Leistungsbereiche</h2>
      <div class="mt-8 grid-auto">
        {services.map((service) => (
          <a class="surface p-6 no-underline" href={`/leistungen/${service.slug}/`}>
            <h3 class="h3">{service.title}</h3>
            <p class="mt-3 text-sm leading-7 text-hsb-steel">{service.problem}</p>
          </a>
        ))}
      </div>
    </div>
  </section>
  {relatedReferences.length > 0 && (
    <section class="section">
      <div class="container">
        <p class="eyebrow">Referenzen</p>
        <h2 class="h2 mt-3">Projektbeispiele aus ähnlichen Bereichen</h2>
        <div class="mt-8 grid-auto">
          {relatedReferences.map((reference) => <ReferenceCard reference={reference} />)}
        </div>
      </div>
    </section>
  )}
  <FAQAccordion faqs={industry.faqs} />
  <CTASection title={industry.ctaLabel} text="Die Branchenanfrage wird mit Belastungen, Systeminteresse und Betriebsfenster qualifiziert." label="Branchenprojekt anfragen" />
</BaseLayout>
