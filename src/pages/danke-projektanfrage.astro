---
import CTASection from "../components/sections/CTASection.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Danke für Ihre Projektanfrage | Hexagon Säurebau" description="Ihre Anfrage wurde vorbereitet. HSB meldet sich zur technischen Bewertung von Industrieboden, Säureschutz oder Sanierung." path="/danke-projektanfrage/">
  <section class="section bg-hsb-mist">
    <div class="container max-w-3xl">
      <p class="eyebrow">Anfrage vorbereitet</p>
      <h1 class="h1 mt-4">Danke für Ihre Projektanfrage</h1>
      <p class="lead mt-6">Die Danke-Seite ist als Conversion-Ziel vorbereitet. Im Livebetrieb wird hier zusätzlich das GA4/GTM-Event <code>lead_form_submit</code> ausgelöst.</p>
      <a class="button-secondary mt-8" href="/">Zur Startseite</a>
    </div>
  </section>
  <CTASection title="Nächster Schritt im Vertrieb" text="Die Anfragefelder sind CRM-kompatibel vorbereitet und können später mit E-Mail, Telefonprozess und Angebotslogik verbunden werden." />
</BaseLayout>
