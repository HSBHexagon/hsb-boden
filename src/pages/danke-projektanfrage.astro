---
import CTASection from "../components/sections/CTASection.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Danke für Ihre Projektanfrage | Hexagon Säurebau" description="Ihre Anfrage wurde vorbereitet. HSB meldet sich zur technischen Bewertung von Industrieboden, Säureschutz oder Sanierung." path="/danke-projektanfrage/">
  <section class="section bg-hsb-mist">
    <div class="container max-w-3xl">
      <p class="eyebrow">Anfrage vorbereitet</p>
      <h1 class="h1 mt-4">Danke für Ihre Projektanfrage</h1>
      <p class="lead mt-6">Vielen Dank – Ihre Anfrage ist bei uns eingegangen. HSB meldet sich in der Regel innerhalb eines Werktags zur technischen Bewertung Ihres Industrieboden-, Säureschutz- oder Sanierungsvorhabens.</p>
      <a class="button-secondary-dark mt-8" href="/">Zur Startseite</a>
    </div>
  </section>
  <CTASection />
</BaseLayout>
