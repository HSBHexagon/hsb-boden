---
import LeadFormSection from "../components/forms/LeadFormSection.astro";
import ReferenceMapPreview from "../components/references/ReferenceMapPreview.astro";
import CTASection from "../components/sections/CTASection.astro";
import HomepageFAQSection from "../components/sections/HomepageFAQSection.astro";
import IndustryGrid from "../components/sections/IndustryGrid.astro";
import ManufacturerProof from "../components/sections/ManufacturerProof.astro";
import ProofMediaSection from "../components/sections/ProofMediaSection.astro";
import SchmerzpunkteSection from "../components/sections/SchmerzpunkteSection.astro";
import ServiceGrid from "../components/sections/ServiceGrid.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
import { buildLocalBusinessJsonLd } from "../lib/schema";
---

<BaseLayout title={site.defaultTitle} description={site.defaultDescription} path="/" jsonLd={[buildLocalBusinessJsonLd()]}>

  <!-- HERO -->
  <section class="bg-hsb-black text-white overflow-hidden">
    <div class="container pb-0 pt-16 lg:pt-20">
      <div class="grid gap-12 lg:grid-cols-[0.92fr_1.08fr] lg:items-stretch">

        <!-- Left: Copy -->
        <div class="pb-14 lg:pb-20">
          <p class="eyebrow-light mb-6">Gronau · NRW · Industrieböden</p>
          <h1 class="h1 max-w-4xl">
            Böden für Bereiche,<br class="hidden sm:block" /> in denen<br class="hidden sm:block" />
            <span class="text-hsb-red">Versagen</span> keine Option ist
          </h1>
          <p class="mt-8 max-w-2xl text-lg leading-8 text-white/65">
            Säureschutz, Keramik, PU-Beton, Entwässerung und Sanierung als technisches System - geplant nach Belastungsprofil, nicht nach Katalog.
          </p>
          <div class="mt-10 flex flex-wrap items-center gap-4">
            <a class="button-primary" href="/kontakt/">Kostenlose Ersteinschätzung anfordern</a>
            <a class="button-secondary" href="/referenzen/">Referenzen ansehen</a>
          </div>

          <!-- Proof strip -->
          <div class="mt-14 flex flex-wrap gap-x-10 gap-y-3 border-t border-white/10 pt-8">
            {[
              ["Analyse vor Ort", "Untergrund, Chemie und Betrieb werden technisch aufgenommen"],
              ["System, nicht Produkt", "Belag, Fuge, Abdichtung und Entwässerung als Einheit geplant"],
              ["Sanierung planbar", "Bauabschnitte und Stillstandsfenster von Anfang an eingeplant"],
            ].map(([label, desc]) => (
              <div class="min-w-[180px]">
                <p class="text-sm font-bold text-white">{label}</p>
                <p class="mt-1 text-xs leading-5 text-white/45 max-w-[200px]">{desc}</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: Visual proof -->
        <div class="grid gap-4 self-stretch lg:grid-rows-[1fr_auto]">
          <div class="relative overflow-hidden rounded-[10px] border border-white/10 bg-black min-h-[320px]">
            <img
              src="/media/hsb/current/industrieboden-baustelle.jpeg"
              alt="Keramischer Industrieboden mit Hexagon-Fliesen und Entwässerungsrinne"
              class="absolute inset-0 h-full w-full object-cover object-center opacity-82"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black via-black/35 to-transparent"></div>
            <div class="relative z-10 flex h-full flex-col justify-end p-6 lg:p-8">
              <p class="eyebrow-light">Ausführung aus der Praxis</p>
              <h2 class="mt-3 text-2xl font-black leading-tight text-white lg:text-[2rem]">
                Keramik, Gefälle und Rinne als System.
              </h2>
              <p class="mt-3 max-w-md text-sm leading-7 text-white/65">
                Reale Flächenbilder zeigen, worauf die neue Website einzahlen muss: saubere Anschlüsse, belastbare Flächen und eine kontrollierte technische Sprache.
              </p>
            </div>
          </div>
          <div class="grid gap-0 overflow-hidden rounded-[10px] border border-white/10 bg-white/5 sm:grid-cols-2">
            {[
              ["Lebensmittelproduktion", "Reinigbarkeit, Hygiene, Säureschutz"],
              ["Molkerei & Brauerei", "Milchsäure, Feuchtigkeit, Gefälle"],
              ["Chemie & Pharma", "Chemikalienbeständigkeit, WHG"],
              ["Sanierung im Betrieb", "Bauabschnitte, kurze Sperrzeiten"],
            ].map(([title, sub], i) => (
              <div class={`border-white/10 p-5 ${i < 2 ? "border-b sm:border-b-0 sm:border-r" : ""} ${i === 2 ? "sm:border-r" : ""} ${i === 3 ? "" : "border-b sm:border-b-0"}`}>
                <p class="text-sm font-bold text-white/90">{title}</p>
                <p class="mt-1.5 text-xs leading-5 text-white/45">{sub}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>

    <!-- Red bottom bar -->
    <div class="h-1 w-full bg-hsb-red mt-1"></div>
  </section>

  <!-- SCHMERZPUNKTE -->
  <SchmerzpunkteSection />

  <!-- LEISTUNGEN -->
  <ServiceGrid />

  <!-- BRANCHEN -->
  <IndustryGrid />

  <!-- VISUELLE SUBSTANZ -->
  <ProofMediaSection />

  <!-- REFERENZEN PREVIEW -->
  <ReferenceMapPreview />

  <!-- PROJEKTABLAUF -->
  <section class="section" id="projektablauf">
    <div class="container">
      <div class="mb-12 max-w-2xl">
        <h2 class="h2">Von Belastungsprofil zu belastbarer Umsetzung</h2>
        <p class="lead mt-4">Jede Entscheidung beginnt mit der Analyse des Ist-Zustands - nicht mit dem Katalog.</p>
      </div>

      <div class="grid gap-0 divide-y divide-hsb-line">
        {[
          ["01", "Analyse vor Ort", "Untergrund, Schäden, Chemiebelastung, Reinigungsprozesse, Gefälle und Betriebsablauf werden technisch aufgenommen. Keine Systemempfehlung ohne diesen Schritt."],
          ["02", "Systementscheidung", "Keramik, PU-Beton, Epoxidharz, Abdichtung und Entwässerung werden nach Belastungsprofil bewertet und nicht nach dem einfachsten Weg."],
          ["03", "Sanierungsfenster planen", "Bauabschnitte, Sperrzeiten, Materialaushärtung und Wiederinbetriebnahme werden von Anfang an mit der Produktionsplanung abgestimmt."],
          ["04", "Dokumentation & Abnahme", "Jede Ausführung wird technisch dokumentiert - für interne Nachvollziehbarkeit, Audit-Vorbereitung und als Grundlage für Wartung und spätere Sanierungsplanung."],
        ].map(([number, title, text]) => (
          <article class="grid gap-6 py-8 sm:grid-cols-[80px_1fr_1.5fr]">
            <span class="text-4xl font-black text-hsb-line tabular-nums">{number}</span>
            <h3 class="h3 self-start">{title}</h3>
            <p class="text-sm leading-7 text-hsb-steel">{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- HERSTELLER -->
  <ManufacturerProof />

  <!-- KONTAKTFORMULAR -->
  <LeadFormSection />

  <!-- FAQ -->
  <HomepageFAQSection />

  <!-- FINAL CTA -->
  <CTASection />

</BaseLayout>
