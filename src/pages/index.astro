---
import LeadFormSection from "../components/forms/LeadFormSection.astro";
import ReferenceMapPreview from "../components/references/ReferenceMapPreview.astro";
import CTASection from "../components/sections/CTASection.astro";
import HomepageFAQSection from "../components/sections/HomepageFAQSection.astro";
import IndustryGrid from "../components/sections/IndustryGrid.astro";
import LogoCloud from "../components/sections/LogoCloud.astro";
import ManufacturerProof from "../components/sections/ManufacturerProof.astro";
import ProofMediaSection from "../components/sections/ProofMediaSection.astro";
import SchmerzpunkteSection from "../components/sections/SchmerzpunkteSection.astro";
import ServiceGrid from "../components/sections/ServiceGrid.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../data/site";
import { homeAlternates } from "../lib/i18n";
import { buildLocalBusinessJsonLd } from "../lib/schema";
---

<BaseLayout title={site.defaultTitle} description={site.defaultDescription} path="/" jsonLd={[buildLocalBusinessJsonLd()]} alternates={homeAlternates}>

  <!-- HERO -->
  <section class="relative overflow-hidden border-b-4 border-hsb-red bg-hsb-black text-white">
    <div class="container relative z-10 pb-0 pt-16 lg:pt-24">
      <div class="grid gap-14 lg:grid-cols-[1.05fr_0.95fr] lg:items-stretch">

        <!-- Left: Copy -->
        <div class="pb-16 lg:pb-24">
          <p class="eyebrow-light mb-7 flex items-center gap-2.5">
            <svg width="11" height="12.7" viewBox="0 0 26 30" fill="none" aria-hidden="true" class="shrink-0">
              <path d="M12.9904 0L25.9808 7.5V22.5L12.9904 30L0 22.5V7.5L12.9904 0Z" fill="#cb0000" />
            </svg>
            Zertifizierter WHG-Fachbetrieb · Industrieböden & Säureschutz
          </p>
          <h1 class="hero-h1 max-w-[18ch]">
            Spezialisierte Industrieböden für Lebensmittel-, Pharma- und <span class="text-hsb-red-light">Chemieproduktion</span>
          </h1>
          <p class="mt-7 max-w-xl text-lg leading-8 text-white/62">
            Technische Fachplanung und bundesweite Ausführung. <span class="font-bold text-white/90">Sanierung ohne Stillstand</span> durch optimierte Taktung und Wochenend-Montage.
          </p>
          <div class="mt-10 flex flex-wrap items-center gap-4">
            <a class="button-primary" href="/kontakt/">Analyse vor Ort anfragen</a>
            <a class="button-secondary" href="/referenzen/">Referenzen ansehen</a>
          </div>
        </div>

        <!-- Right: Visual proof -->
        <div class="grid self-stretch gap-5 pb-12 lg:grid-rows-[1fr_auto] lg:pb-0">
          <div class="group relative min-h-[400px] overflow-hidden rounded-[4px] border border-white/10 bg-black lg:min-h-[580px]">
            <img
              src="/media/hsb/current/industrieboden-baustelle.webp"
              srcset="/media/hsb/current/industrieboden-baustelle-640.webp 640w, /media/hsb/current/industrieboden-baustelle.webp 1024w"
              sizes="(min-width: 1024px) 50vw, 100vw"
              alt="Keramischer Industrieboden mit Entwässerungsrinne und Hexagon-Verlegung in Produktionshalle"
              class="absolute inset-0 h-full w-full object-cover object-center transition-transform duration-700 group-hover:scale-105"
              style="opacity:0.75"
              fetchpriority="high"
              loading="eager"
              decoding="async"
              width="1024"
              height="768"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-black via-black/45 to-transparent"></div>
            <div class="relative z-10 flex h-full flex-col justify-end p-8 lg:p-10">
              <div class="eyebrow-light mb-4 flex items-center gap-2">
                <span class="size-1 bg-hsb-red"></span>
                <span>Referenz-Projekt</span>
              </div>
              <h2 class="text-2xl font-black leading-tight text-white lg:text-[2rem]">
                Keramik, Entwässerung und Gefälle aus einem System.
              </h2>
              <p class="mt-4 max-w-md text-sm leading-7 text-white/72">
                Industrieböden für Lebensmittelbetriebe müssen Säurebelastung, Reinigungsdruck und Auditanforderungen dauerhaft bestehen.
              </p>
            </div>
          </div>
          <div class="grid gap-0 overflow-hidden rounded-[4px] border border-white/10 bg-white/5 sm:grid-cols-2">
            {[
              ["Lebensmittelproduktion", "Reinigbarkeit, Hygiene, Säureschutz"],
              ["Molkerei & Brauerei", "Milchsäure, Feuchtigkeit, Gefälle"],
              ["Chemie & Pharma", "Chemikalienbeständigkeit, WHG"],
              ["Sanierung im Betrieb", "Bauabschnitte, kurze Sperrzeiten"],
            ].map(([title, sub], i) => (
              <div class={`border-white/10 p-6 ${i < 2 ? "border-b sm:border-b-0 sm:border-r" : ""} ${i === 2 ? "sm:border-r" : ""} ${i === 3 ? "" : "border-b sm:border-b-0"}`}>
                <p class="mb-1.5 text-[0.75rem] font-black uppercase tracking-[0.16em] text-hsb-red-light">{title}</p>
                <p class="text-xs leading-5 text-white/62">{sub}</p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>

  </section>

  <!-- LOGO CLOUD -->
  <LogoCloud />

  <section class="border-b border-hsb-line bg-white">
    <div class="container py-10 lg:py-12">
      <h2 class="h2 max-w-2xl">Planung und Ausführung aus einer Hand</h2>
      <p class="lead mt-3 max-w-2xl">Vom ersten Vor-Ort-Termin bis zur Abnahme: Keramik, Säureschutz, Entwässerung und Sanierung laufen über einen Ansprechpartner – ohne Schnittstellenverlust zwischen Planung und Gewerk.</p>
    </div>
    <div class="container grid gap-0 divide-y divide-hsb-line py-0 lg:grid-cols-3 lg:divide-x lg:divide-y-0">
      {[
        ["Analyse vor Ort", "Untergrund, Chemie und Betrieb werden technisch aufgenommen."],
        ["System, nicht Produkt", "Belag, Fuge, Abdichtung und Entwässerung werden als Einheit geplant."],
        ["Sanierung planbar", "Bauabschnitte und Stillstandsfenster werden von Anfang an eingeplant."],
      ].map(([label, desc]) => (
        <div class="py-6 lg:px-8">
          <p class="text-[0.72rem] font-black uppercase tracking-[0.16em] text-hsb-red">{label}</p>
          <p class="mt-2 max-w-sm text-sm leading-6 text-hsb-steel">{desc}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- SCHMERZPUNKTE -->
  <SchmerzpunkteSection />

  <!-- LEISTUNGEN -->
  <ServiceGrid />

  <!-- BRANCHEN -->
  <IndustryGrid />

  <!-- VISUELLE SUBSTANZ -->
  <ProofMediaSection />

  <!-- REFERENZEN PREVIEW -->
  <ReferenceMapPreview />

  <!-- PROJEKTABLAUF -->
  <section class="section bg-[#f8f9fb]" id="projektablauf">
    <div class="container">
      <div class="mb-14 max-w-2xl">
        <p class="eyebrow mb-4">Planung & Realisierung</p>
        <h2 class="h2">Von Belastungsprofil zu belastbarer Umsetzung</h2>
        <p class="lead mt-5">Jede Entscheidung beginnt mit der Analyse des Ist-Zustands. Nicht mit dem Katalog.</p>
      </div>

      <div class="grid gap-0 border-t border-hsb-line">
        {[
          ["01", "Analyse vor Ort", "Untergrund, Schäden, Chemiebelastung, Reinigungsprozesse, Gefälle und Betriebsablauf werden technisch aufgenommen. Keine Systemempfehlung ohne diesen Schritt."],
          ["02", "Systementscheidung", "Keramik, PU-Beton, Epoxidharz, Abdichtung und Entwässerung werden nach Belastungsprofil bewertet und nicht nach dem einfachsten Weg."],
          ["03", "Sanierungsfenster planen", "Bauabschnitte, Sperrzeiten, Materialaushärtung und Wiederinbetriebnahme werden von Anfang an mit der Produktionsplanung abgestimmt."],
          ["04", "Dokumentation und Abnahme", "Jede Ausführung wird technisch dokumentiert: für interne Nachvollziehbarkeit, Audit-Vorbereitung und als Grundlage für Wartung und spätere Sanierungsplanung."],
        ].map(([number, title, text]) => (
          <article class="group grid items-baseline gap-7 border-b border-hsb-line px-4 py-10 transition-colors duration-300 hover:bg-white lg:-mx-4 lg:grid-cols-[112px_1fr_1.5fr]">
            <div class="flex items-center gap-4">
              <span class="font-mono text-[0.65rem] font-black tracking-[0.24em] text-hsb-red">STEP</span>
              <span class="text-4xl font-black text-hsb-black tabular-nums">{number}</span>
            </div>
            <h3 class="text-xl font-black leading-tight text-hsb-black transition-colors group-hover:text-hsb-red">{title}</h3>
            <p class="max-w-xl text-[0.95rem] leading-7 text-hsb-steel">{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- HERSTELLER -->
  <ManufacturerProof />

  <!-- KONTAKTFORMULAR -->
  <LeadFormSection />

  <!-- FAQ -->
  <HomepageFAQSection />

  <!-- FINAL CTA -->
  <CTASection />

</BaseLayout>
