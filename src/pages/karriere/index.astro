---
import CTASection from "../../components/sections/CTASection.astro";
import PageHero from "../../components/sections/PageHero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Karriere bei Hexagon Säurebau | Industrieboden-Projekte" description="Karriere bei HSB: Arbeiten an anspruchsvollen Industrieböden, Säureschutzsystemen und Sanierungsprojekten in Produktionsbetrieben." path="/karriere/">
  <PageHero eyebrow="Karriere" title="Karriere bei Hexagon Säurebau" text="HSB braucht Menschen, die technische Baustellen, saubere Ausführung und industrielle Produktionsumgebungen ernst nehmen." ctaLabel="Kontakt aufnehmen" />
  <section class="section">
    <div class="container grid-auto">
      {["Fliesenleger (m/w/d)", "Bauhelfer mit Industrieerfahrung", "Projektleitung Industrieboden"].map((role) => (
        <article class="surface p-6">
          <h2 class="h3">{role}</h2>
          <p class="mt-3 text-sm leading-7 text-hsb-steel">Arbeiten an keramischen Industrieböden, Säureschutzsystemen, Sanierungen und technischen Detailpunkten in Lebensmittel-, Getränke- und Industrieproduktion.</p>
          <a class="mt-5 inline-block text-sm font-black text-hsb-red" href="/kontakt/">Bewerbung anfragen</a>
        </article>
      ))}
    </div>
  </section>
  <CTASection title="Team für anspruchsvolle Industrieprojekte" text="Karriere bleibt im Projekt enthalten, wird aber klar vom Leadformular für Kundenanfragen getrennt." label="Kontakt aufnehmen" />
</BaseLayout>
