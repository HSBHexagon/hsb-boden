---
import ReferenceCard from "../../components/references/ReferenceCard.astro";
import CTASection from "../../components/sections/CTASection.astro";
import FAQAccordion from "../../components/sections/FAQAccordion.astro";
import ManufacturerProof from "../../components/sections/ManufacturerProof.astro";
import PageHero from "../../components/sections/PageHero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getArticles, getIndustries, getReferencesForSlugs, getServices } from "../../lib/content";
import { buildBreadcrumbJsonLd, buildFaqJsonLd, buildServiceJsonLd } from "../../lib/schema";

export const prerender = true;

export function getStaticPaths() {
  return getServices().map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;
const relatedReferences = getReferencesForSlugs(service.relatedReferences);
const relatedIndustries = getIndustries().filter((industry) => service.relatedIndustries.includes(industry.slug));
const relatedArticles = getArticles().filter((article) => service.relatedArticles.includes(article.slug));
const path = `/leistungen/${service.slug}/`;

// Reale Projektfotos aus dem HSB-Arbeitsumfeld (keine Stockfotos) für Leistungen,
// zu denen ein passendes, freigegebenes Motiv vorliegt.
const serviceImages: Record<string, { src: string; alt: string }> = {
  "industrieboden-saeureschutz": {
    src: "/media/hsb/projekte/saeulen-anschluss-keramik.webp",
    alt: "Dicht ausgeführter Säulen- und Sockelanschluss in Sechskant-Keramik, Detail einer Produktionsfläche",
  },
  "keramische-industrieboeden": {
    src: "/media/hsb/projekte/verlegung-keramik.webp",
    alt: "Verlegung eines keramischen Sechskant-Industriebodens während der Ausführung",
  },
};

const serviceImage = serviceImages[service.slug];
---

<BaseLayout title={service.seoTitle} description={service.description} path={path} jsonLd={[buildServiceJsonLd({ name: service.title, description: service.description, path }), buildFaqJsonLd(service.faqs), buildBreadcrumbJsonLd([{ name: "Start", path: "/" }, { name: "Leistungen", path: "/leistungen/" }, { name: service.title, path }])]}>
  <PageHero eyebrow="Leistung" title={service.h1} text={service.description} ctaLabel={service.ctaLabel} />
  {serviceImage && (
    <section class="section-tight">
      <div class="container">
        <figure class="overflow-hidden rounded-[10px] border border-hsb-line">
          <!-- ⚡ Bolt Optimization: Hero image is LCP candidate, removed lazy loading and added high fetchpriority -->
          <img src={serviceImage.src} alt={serviceImage.alt} class="max-h-[480px] w-full object-cover object-center" fetchpriority="high" loading="eager" decoding="async" width="1200" height="480" />
          <figcaption class="border-t border-hsb-line bg-white px-5 py-3 text-xs font-bold text-hsb-steel">
            Reale Projektfläche aus dem HSB-Arbeitsumfeld – keine Stockfotos.
          </figcaption>
        </figure>
      </div>
    </section>
  )}
  <section class="section">
    <div class="container grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
      <div>
        <p class="eyebrow">Problem</p>
        <h2 class="h2 mt-3">Warum diese Leistung relevant ist</h2>
        <p class="lead mt-4">{service.problem}</p>
      </div>
      <div class="grid gap-4">
        <article class="surface p-6">
          <h3 class="h3">Systemlösung</h3>
          <p class="mt-3 text-sm leading-7 text-hsb-steel">{service.systemSolution}</p>
        </article>
        <article class="surface p-6">
          <h3 class="h3">Technische Anforderungen</h3>
          <div class="mt-4 flex flex-wrap gap-2">
            {service.technicalRequirements.map((item) => <span class="rounded bg-hsb-mist px-3 py-2 text-sm font-bold text-hsb-steel">{item}</span>)}
          </div>
        </article>
      </div>
    </div>
  </section>
  <section class="section-tight bg-hsb-mist">
    <div class="container grid gap-6 lg:grid-cols-2">
      <div class="surface p-6">
        <h2 class="h3">Vorteile</h2>
        <ul class="mt-4 space-y-2 text-sm leading-6 text-hsb-steel">
          {service.benefits.map((item) => <li>• {item}</li>)}
        </ul>
      </div>
      <div class="surface p-6">
        <h2 class="h3">Entscheidungskriterien</h2>
        <ul class="mt-4 space-y-2 text-sm leading-6 text-hsb-steel">
          {service.decisionCriteria.map((item) => <li>• {item}</li>)}
        </ul>
      </div>
    </div>
  </section>
  {relatedIndustries.length > 0 && (
    <section class="section-tight">
      <div class="container">
        <p class="eyebrow">Einsatzbereiche</p>
        <h2 class="h2 mt-3">Für welche Branchen relevant</h2>
        <div class="mt-8 grid-auto">
          {relatedIndustries.map((industry) => (
            <a class="surface p-6 no-underline" href={`/branchen/${industry.slug}/`}>
              <h3 class="h3">{industry.title}</h3>
              <p class="mt-3 text-sm leading-7 text-hsb-steel">{industry.searchIntent}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
  {service.slug.includes("keramische") || service.slug.includes("saeureschutz") ? <ManufacturerProof /> : null}
  {relatedReferences.length > 0 && (
    <section class="section">
      <div class="container">
        <p class="eyebrow">Passende Referenzen</p>
        <h2 class="h2 mt-3">Projektbeispiele mit Freigabelogik</h2>
        <div class="mt-8 grid-auto">
          {relatedReferences.map((reference) => <ReferenceCard reference={reference} />)}
        </div>
      </div>
    </section>
  )}
  {relatedArticles.length > 0 && (
    <section class="section-tight bg-hsb-mist">
      <div class="container">
        <p class="eyebrow">Wissen</p>
        <h2 class="h2 mt-3">Vertiefendes Fachwissen</h2>
        <div class="mt-8 grid-auto">
          {relatedArticles.map((article) => (
            <a class="surface p-6 no-underline" href={`/wissen/${article.slug}/`}>
              <p class="eyebrow">{article.category}</p>
              <h3 class="h3 mt-2">{article.title}</h3>
              <p class="mt-3 text-sm leading-7 text-hsb-steel">{article.intro}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
  <FAQAccordion faqs={service.faqs} />
  <CTASection title={service.ctaLabel} text="Die technische Ersteinschätzung startet mit Belastung, Fläche, Nutzung, Untergrund und Zeitfenster." label="Anfrage starten" />
</BaseLayout>
