---
import CTASection from "../../components/sections/CTASection.astro";
import PageHero from "../../components/sections/PageHero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";

const phases = [
  {
    number: "01",
    title: "Analyse vor Ort",
    text: "Untergrund, Schadensbild, Belastungen, Entwässerung, Anschlüsse und betriebliche Rahmenbedingungen werden gemeinsam aufgenommen. Die Bestandsanalyse bildet die Grundlage für alle weiteren Entscheidungen.",
    checks: ["Untergrund und Schadstellen", "Chemische, thermische und mechanische Belastung", "Gefälle, Rinnen und Anschlüsse", "Produktions- und Reinigungsabläufe"],
  },
  {
    number: "02",
    title: "Systemauslegung",
    text: "Auf Basis des Belastungsprofils werden Belag, Fuge, Abdichtung, Entwässerung und technische Details als zusammenhängendes Bodensystem bewertet. Die Auswahl richtet sich nach dem konkreten Einsatzbereich.",
    checks: ["Belag und Fugenaufbau", "Abdichtung und Säureschutz", "Entwässerung und Detailanschlüsse", "Bauabschnitte und Schnittstellen"],
  },
  {
    number: "03",
    title: "Untergrundvorbereitung",
    text: "Der vorhandene Aufbau wird für das vorgesehene System vorbereitet. Dazu gehören je nach Bestand der kontrollierte Rückbau, die Bearbeitung des Untergrunds und die Vorbereitung von Anschlüssen und Einbauteilen.",
    checks: ["Kontrollierter Rückbau", "Tragfähiger und geeigneter Untergrund", "Vorbereitung von Rinnen und Durchdringungen", "Abgrenzung der Arbeitsbereiche"],
  },
  {
    number: "04",
    title: "Einbau und Ausführung",
    text: "Die abgestimmten Systembestandteile werden in der geplanten Reihenfolge eingebaut. Ausführung, Übergänge und Detailpunkte werden fortlaufend gegen die vereinbarte Planung geprüft.",
    checks: ["Einbau nach abgestimmtem Systemaufbau", "Ausbildung von Gefälle und Übergängen", "Anschluss an Rinnen und Einbauteile", "Koordination der vorgesehenen Bauabschnitte"],
  },
  {
    number: "05",
    title: "Abnahme und Dokumentation",
    text: "Nach Abschluss werden die ausgeführten Bereiche gemeinsam betrachtet. Relevante Details, Anschlüsse und Hinweise für Betrieb, Reinigung oder spätere Instandhaltung werden nachvollziehbar dokumentiert.",
    checks: ["Gemeinsame Sichtprüfung", "Dokumentation relevanter Detailpunkte", "Hinweise für Reinigung und Betrieb", "Grundlage für spätere Wartung und Instandsetzung"],
  },
];
---

<BaseLayout
  title="Projektablauf für Industrieböden und Säureschutz | HSB"
  description="Vom Belastungsprofil bis zur Abnahme: So strukturiert HSB Analyse, Systemauslegung, Untergrundvorbereitung, Einbau und Dokumentation von Industriebodenprojekten."
  path="/projektablauf/"
>
  <PageHero
    eyebrow="Planung & Realisierung"
    title="Ein klarer Projektablauf für produktionskritische Bodenflächen"
    text="Industriebodenprojekte beginnen mit dem tatsächlichen Bestand. HSB strukturiert Analyse, technische Auslegung, Vorbereitung, Ausführung und Dokumentation als nachvollziehbare Schritte."
    ctaLabel="Projekt besprechen"
  />

  <section class="section border-b border-hsb-line bg-white" aria-labelledby="projektphasen-heading">
    <div class="container">
      <div class="max-w-3xl">
        <p class="eyebrow mb-4">Fünf Projektphasen</p>
        <h2 class="h2" id="projektphasen-heading">Vom Ist-Zustand zur dokumentierten Ausführung</h2>
        <p class="lead mt-5 text-hsb-steel">
          Umfang und Reihenfolge werden an Bestand, Belastungsprofil und betriebliche Anforderungen angepasst. Die folgenden Phasen zeigen den grundsätzlichen Ablauf.
        </p>
      </div>

      <ol class="mt-14 grid gap-6">
        {phases.map((phase) => (
          <li class="grid gap-8 border-t border-hsb-line py-10 lg:grid-cols-[96px_0.9fr_1.1fr] lg:items-start">
            <div class="flex items-center gap-3">
              <span class="font-mono text-[0.65rem] font-black uppercase tracking-[0.2em] text-hsb-red">Phase</span>
              <span class="text-4xl font-black tabular-nums text-hsb-black">{phase.number}</span>
            </div>
            <div>
              <h3 class="text-2xl font-black leading-tight text-hsb-black">{phase.title}</h3>
              <p class="mt-4 max-w-xl text-base leading-7 text-hsb-steel">{phase.text}</p>
            </div>
            <ul class="grid gap-3" aria-label={`Prüfpunkte: ${phase.title}`}>
              {phase.checks.map((check) => (
                <li class="flex items-start gap-3 border-b border-hsb-line pb-3 text-sm leading-6 text-hsb-steel last:border-0">
                  <span class="mt-2 size-2 shrink-0 bg-hsb-red" aria-hidden="true"></span>
                  <span>{check}</span>
                </li>
              ))}
            </ul>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section bg-hsb-mist" aria-labelledby="vorbereitung-heading">
    <div class="container grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div>
        <p class="eyebrow mb-4">Vor dem ersten Termin</p>
        <h2 class="h2" id="vorbereitung-heading">Diese Informationen erleichtern die technische Ersteinschätzung</h2>
      </div>
      <div class="grid gap-px overflow-hidden rounded-[4px] border border-hsb-line bg-hsb-line sm:grid-cols-2">
        {[
          ["Fläche und Nutzung", "Betroffener Bereich, ungefähre Größe und aktuelle Nutzung der Fläche."],
          ["Schadensbild", "Fotos oder eine kurze Beschreibung von Rissen, Fugen, Ablösungen und Entwässerungsproblemen."],
          ["Belastungen", "Reinigungschemie, Temperaturwechsel, Feuchtigkeit, Verkehr und weitere bekannte Beanspruchungen."],
          ["Betriebliche Grenzen", "Verfügbare Zeitfenster, sensible Nachbarbereiche und bekannte Schnittstellen."],
        ].map(([title, text]) => (
          <article class="bg-white p-7">
            <h3 class="text-base font-black text-hsb-black">{title}</h3>
            <p class="mt-3 text-sm leading-6 text-hsb-steel">{text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <CTASection
    title="Projektablauf für Ihre Fläche abstimmen"
    text="Schildern Sie Bestand, Belastungen und betriebliche Rahmenbedingungen. HSB ordnet ein, welche Informationen für den nächsten technischen Schritt benötigt werden."
    label="Ersteinschätzung anfragen"
  />
</BaseLayout>
