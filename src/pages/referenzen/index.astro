---
import ReferenceCard from "../../components/references/ReferenceCard.astro";
import ReferenceMap from "../../components/references/ReferenceMap.astro";
import CTASection from "../../components/sections/CTASection.astro";
import PageHero from "../../components/sections/PageHero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { clientLocations } from "../../data/clientLocations";
import { getPublicReferences } from "../../lib/content";

const references = getPublicReferences();
---

<BaseLayout title="Referenzen Industrieböden & Säureschutz | HSB Hexagon Säurebau" description="Referenzen für keramische Industrieböden, Säureschutz, Entwässerung und Industrieboden-Sanierung. Lebensmittelproduktion, Molkerei, Brauerei, Chemie und NRW." path="/referenzen/">
  <PageHero eyebrow="Referenzen" title="Ausgeführte Industrieböden für produktionskritische Bereiche" text="Freigegebene und anonymisierte Referenzen zeigen, welche Belastungen, Systeme und Branchen Hexagon Säurebau kennt – konkret beschrieben nach Herausforderung, System und Ergebnis." />

  <!-- Fotogalerie: echte Referenzflächen -->
  <section class="section-tight border-b border-hsb-line bg-hsb-mist">
    <div class="container">
      <div class="mb-8 max-w-3xl">
        <p class="eyebrow">Ausgeführte Flächen</p>
        <h2 class="h2 mt-4">Reale Bodenflächen statt Symbolbilder</h2>
        <p class="lead mt-4">
          Die Bilder zeigen Oberflächen, Rinnenanschlüsse und Detailbereiche aus dem HSB-Arbeitsumfeld. Sie stehen für Ausführungsqualität, nicht für freigegebene Kundennamen.
        </p>
      </div>
      <div class="grid gap-5 lg:grid-cols-[1.25fr_0.75fr]">
        <figure class="overflow-hidden rounded-[4px] border border-hsb-line bg-white">
          <div class="aspect-[16/10] overflow-hidden bg-hsb-black">
            <img
              src="/media/hsb/current/referenzflaeche-1.webp"
              alt="Keramischer Industrieboden mit Entwässerungsrinne als Referenzfläche von Hexagon Säurebau"
              class="h-full w-full object-cover object-center transition-transform duration-500 hover:scale-[1.015]"
              loading="lazy"
              width="554"
              height="361"
            />
          </div>
          <figcaption class="grid gap-2 px-5 py-4 text-sm leading-6 text-hsb-steel">
            <span class="text-xs font-black uppercase tracking-[0.14em] text-hsb-red">Keramik und Entwässerungsrinne</span>
            Gefälle, Rinnenkante und Fliesenbild müssen zusammen geplant werden.
          </figcaption>
        </figure>
        <div class="grid gap-5">
          {[
            {
              src: "/media/hsb/current/referenzflaeche-2.webp",
              alt: "Hygienische Industrieverfliesung für Lebensmittelproduktion",
              label: "Hygienische Verfliesung",
              text: "Oberflächenbild und Fugenführung für reinigungsintensive Produktionsbereiche.",
            },
            {
              src: "/media/hsb/current/referenzflaeche-3.webp",
              alt: "Säurebeständige Bodenfläche in Industrieumgebung von Hexagon Säurebau",
              label: "Säureschutz und Anschlussdetails",
              text: "Detailausbildung entscheidet darüber, ob eine Fläche dauerhaft belastbar bleibt.",
            },
          ].map((img) => (
            <figure class="grid overflow-hidden rounded-[4px] border border-hsb-line bg-white sm:grid-cols-[190px_1fr] lg:grid-cols-1">
              <div class="aspect-[4/3] overflow-hidden sm:aspect-auto lg:aspect-[4/3]">
                <img
                  src={img.src}
                  alt={img.alt}
                  class="h-full w-full object-cover object-center transition-transform duration-500 hover:scale-[1.015]"
                  loading="lazy"
                  width="562"
                  height="369"
                />
              </div>
              <figcaption class="grid gap-2 px-5 py-4 text-sm leading-6 text-hsb-steel">
                <span class="text-xs font-black uppercase tracking-[0.14em] text-hsb-red">{img.label}</span>
                {img.text}
              </figcaption>
            </figure>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Weitere Eindrücke aus der Ausführung -->
  <section class="section-tight">
    <div class="container">
      <div class="mb-8 max-w-3xl">
        <p class="eyebrow">Weitere Eindrücke</p>
        <h2 class="h2 mt-4">Hallen, Rinnen und Bodenanschlüsse aus dem Arbeitsalltag</h2>
      </div>
      <div class="grid gap-5 sm:grid-cols-3">
        {[
          {
            src: "/media/hsb/projekte/keramik-halle-rinnen.webp",
            alt: "Helle Produktionshalle mit zwei parallelen Entwässerungsrinnen in Sechskant-Keramikboden",
            label: "Doppelrinne in der Halle",
            text: "Zwei parallele Rinnenläufe für klare Gefällebahnen auf großer Fläche.",
          },
          {
            src: "/media/hsb/projekte/hexagon-rinne-detail.webp",
            alt: "Edelstahl-Entwässerungsrinne mit Rost, gerade verlegt in Sechskant-Pflasterboden",
            label: "Rinne mit Edelstahlrost",
            text: "Sauberer Anschluss zwischen Rinnenrahmen und Sechskantfliese.",
          },
          {
            src: "/media/hsb/projekte/halle-in-ausfuehrung.webp",
            alt: "Industriehalle während der Verlegung des Sechskant-Keramikbodens",
            label: "Halle in Ausführung",
            text: "Großflächige Verlegung mit klarer Bauabschnittsplanung.",
          },
        ].map((img) => (
          <figure class="overflow-hidden rounded-[4px] border border-hsb-line bg-white">
            <div class="aspect-[4/3] overflow-hidden">
              <img
                src={img.src}
                alt={img.alt}
                class="h-full w-full object-cover object-center transition-transform duration-500 hover:scale-[1.015]"
                loading="lazy"
                width="562"
                height="421"
              />
            </div>
            <figcaption class="grid gap-2 px-5 py-4 text-sm leading-6 text-hsb-steel">
              <span class="text-xs font-black uppercase tracking-[0.14em] text-hsb-red">{img.label}</span>
              {img.text}
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container grid gap-8 lg:grid-cols-[0.92fr_1.08fr] lg:items-start">
      <ReferenceMap references={references} clients={clientLocations} />
      <div class="grid gap-4">
        {references.map((reference) => <ReferenceCard reference={reference} />)}
      </div>
    </div>
  </section>
  <CTASection title="Industriebodenprojekt anfragen" text="HSB plant keramische Industrieböden, Säureschutz, PU-Beton, Entwässerung und Sanierungen für Lebensmittel-, Getränke-, Pharma- und Chemiebetriebe. Schwerpunkt NRW und Münsterland." />
</BaseLayout>
