---
import CTASection from "../../../components/sections/CTASection.astro";
import PageHero from "../../../components/sections/PageHero.astro";
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Industrieboden Bayern | Keramische Böden & Säureschutz München"
  description="HSB Hexagon – Ihr Spezialist für keramische Industrieböden, Säureschutzsysteme und Entwässerung in Bayern. Projekte in München, Nürnberg, Augsburg, Regensburg und ganz Bayern."
  canonical="https://www.hsb-boden.de/standorte/bayern/"
>
  <PageHero
    eyebrow="Region Bayern"
    title="Industrieboden-Spezialist in Bayern"
    text="HSB Hexagon realisiert anspruchsvolle Industriebodenprojekte in München, Nürnberg, Augsburg, Regensburg und der gesamten Region Bayern."
  />

  <section class="section">
    <div class="container">
      <div class="prose max-w-3xl mx-auto">
        <h2>Keramische Industrieböden in Bayern</h2>
        <p>
          Als erfahrener Fachbetrieb für keramische Industrieböden und Säureschutzsysteme sind wir in ganz
          Bayern tätig. Ob Brauereien und Getreidewerke in München, Lebensmittelbetriebe in Nürnberg oder
          Chemiewerke in Augsburg – HSB Hexagon liefert dauerhaft belastbare Bodensysteme für Industrie und Gewerbe.
        </p>

        <h2>Unsere Leistungen in Bayern</h2>
        <ul>
          <li><strong>Keramische Industrieböden</strong> – rutschhemmend, hygienekonform, chemikalienbeständig</li>
          <li><strong>Säureschutzsysteme</strong> – für Chemieindustrie, Brauereien und Lebensmittelbetriebe</li>
          <li><strong>Entwässerungssysteme</strong> – GFK-Rinnen, Punktabläufe, Ex-Zonen</li>
          <li><strong>Industrieboden-Sanierung</strong> – Reparatur und Erneuerung bestehender Böden</li>
          <li><strong>Epoxidharz & Beschichtung</strong> – für leichte bis mittlere Belastungen</li>
        </ul>

        <h2>Regionale Präsenz in Bayern</h2>
        <p>
          Wir betreuen Projekte in der gesamten Region Bayern:
          München, Nürnberg, Augsburg, Regensburg, Ingolstadt, Würzburg, Passau und Umgebung.
          Kurze Wege, schnelle Reaktionszeiten und fundiertes Know-how für bayerische Industriebetriebe.
        </p>
      </div>
    </div>
  </section>

  <CTASection
    title="Projekt in Bayern anfragen"
    text="Kontaktieren Sie uns für eine unverbindliche Beratung zu Ihrem Industriebodenprojekt in Bayern."
  />

  <!-- LocalBusiness + Service Schema for Bayern -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Hexagon Säurebau GmbH",
    "description": "Spezialist für keramische Industrieböden, Säureschutzsysteme und Entwässerung in Bayern",
    "url": "https://www.hsb-boden.de",
    "areaServed": [
      {"@type": "City", "name": "München"},
      {"@type": "City", "name": "Nürnberg"},
      {"@type": "City", "name": "Augsburg"},
      {"@type": "City", "name": "Regensburg"},
      {"@type": "City", "name": "Ingolstadt"},
      {"@type": "City", "name": "Würzburg"},
      {"@type": "AdministrativeArea", "name": "Bayern"}
    ],
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Industrieboden-Leistungen Bayern",
      "itemListElement": [
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Keramische Industrieböden Bayern"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Säureschutzsysteme Bayern"}},
        {"@type": "Offer", "itemOffered": {"@type": "Service", "name": "Industrieboden-Sanierung Bayern"}}
      ]
    },
    "sameAs": "https://www.hsb-boden.de"
  })} />
</BaseLayout>
