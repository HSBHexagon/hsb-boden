---
import CTASection from "../../components/sections/CTASection.astro";
import PageHero from "../../components/sections/PageHero.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getArticles, getIndustries, getServices } from "../../lib/content";
import { buildArticleJsonLd, buildBreadcrumbJsonLd } from "../../lib/schema";

export const prerender = true;

export function getStaticPaths() {
  return getArticles().map((article) => ({
    params: { slug: article.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const path = `/wissen/${article.slug}/`;
const titleLower = article.title.replace(/[?!.]+$/, "").toLowerCase();
const relatedServices = getServices().filter((service) => article.relatedServices.includes(service.slug));
const relatedIndustries = getIndustries().filter((industry) => article.relatedIndustries.includes(industry.slug));
---

<BaseLayout title={article.seoTitle} description={article.description} path={path} jsonLd={[buildBreadcrumbJsonLd([{ name: "Start", path: "/" }, { name: "Wissen", path: "/wissen/" }, { name: article.title, path }]), buildArticleJsonLd({ headline: article.h1, description: article.description, path })]}>
  <PageHero eyebrow={article.category} title={article.h1} text={article.description} ctaLabel="Werksbegehung anfragen" />
  <article class="section">
    <div class="container max-w-3xl">
      <p class="lead">{article.intro}</p>
      <div class="prose prose-lg mt-10 max-w-none">
        {article.sections.map((section, index) => (
          <section>
            <h2>{section.title}</h2>
            <p>
              {section.body
                ? section.body
                : index === 0
                  ? `Dieser Abschnitt ordnet ${titleLower} technisch ein und zeigt, welche Anforderungen in produktionskritischen Bereichen tatsächlich entscheidend sind.`
                  : index === article.sections.length - 1
                    ? `Für Entscheider zählt am Ende, welche Systemwahl dauerhaft tragfähig ist, welche Risiken vermieden werden und wie sich die Maßnahme organisatorisch in den Betrieb einfügt.`
                    : `Im Bereich „${section.title}“ geht es um die Entscheidungskriterien, die bei ${article.category}-Themen über Dauerhaftigkeit, Reinigbarkeit und wirtschaftliche Sanierung entscheiden.`}
            </p>
          </section>
        ))}
      </div>
    </div>
  </article>
  {(relatedServices.length > 0 || relatedIndustries.length > 0) && (
    <section class="section-tight bg-hsb-mist">
      <div class="container">
        <p class="eyebrow">Weiterführend</p>
        <h2 class="h2 mt-3">Passende Leistungen und Branchen</h2>
        <div class="mt-8 grid-auto">
          {relatedServices.map((service) => (
            <a class="surface p-6 no-underline" href={`/leistungen/${service.slug}/`}>
              <p class="eyebrow">Leistung</p>
              <h3 class="h3 mt-2">{service.title}</h3>
              <p class="mt-3 text-sm leading-7 text-hsb-steel">{service.problem}</p>
            </a>
          ))}
          {relatedIndustries.map((industry) => (
            <a class="surface p-6 no-underline" href={`/branchen/${industry.slug}/`}>
              <p class="eyebrow">Branche</p>
              <h3 class="h3 mt-2">{industry.title}</h3>
              <p class="mt-3 text-sm leading-7 text-hsb-steel">{industry.searchIntent}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}
  <CTASection title="Aus Wissen eine Projektentscheidung machen" text="HSB übersetzt die fachlichen Kriterien in eine konkrete Systementscheidung für Ihre Produktionsfläche." />
</BaseLayout>
